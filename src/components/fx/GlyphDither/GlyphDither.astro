---
import styles from "./glyphDither.module.scss";

export interface Props {
  text?: string;
}

const { text = "404" } = Astro.props;
---

<div class={styles.GlyphDither} data-glyph-dither>
  <h1 class={styles.GlyphDither_source} aria-hidden="true">{text}</h1>
  <canvas class={styles.GlyphDither_output} data-glyph-output aria-hidden="true"></canvas>
</div>

<script>
  const GLYPH_PRESETS = {
    default: " .:-=+*#%@",
    blocks: " ░▒▓█",
    ascii:
      " `.-':_,^=;><+!rc*/z?sLTv)J7(|Fi{C}fI31tlu[neoZ5Yxjya]2ESwqkP6h9d4VpOGbUAKXHm8RD#$Bg0MNWQ%&@",
    braille:
      " ⠁⠂⠃⠄⠅⠆⠇⠈⠉⠊⠋⠌⠍⠎⠏⠐⠑⠒⠓⠔⠕⠖⠗⠘⠙⠚⠛⠜⠝⠞⠟⠠⠡⠢⠣⠤⠥⠦⠧⠨⠩⠪⠫⠬⠭⠮⠯⠰⠱⠲⠳⠴⠵⠶⠷⠸⠹⠺⠻⠼⠽⠾⠿",
  } as const;

  const DEFAULT_PARAMS = {
    preset: "default" as keyof typeof GLYPH_PRESETS,
    cellSize: 12, // fixed glyph cell size in px — decoupled from font size so a
    //               bigger "404" is filled with MORE cells, not bigger ones

    glyphScale: 1.3,
    fontScale: 1.2,
    edgeSoftness: 0.38,
    foregroundBrightness: 1.5,
    midtoneBrightness: 0.53,
    backgroundOpacity: 0,
    contrast: 1.39,
    thresholdBias: -0.03,
    gamma: 1.06,
    noiseAmount: 0,
    rippleScale: 24,
    rippleStrength: 100,
    rippleViscosity: 53,
    rippleDecay: 71,
    rippleChromatic: 150,
    rippleSpeed: 100,
    rippleMomentum: 100,
    rippleTrail: 30,
    rippleDirectionality: 10,
    rippleIrregularity: 30,
  };

  type Params = typeof DEFAULT_PARAMS;

  const MAX_RIPPLES = 16;
  const MIN_DISTANCE_PX = 6;
  const MIN_INTERVAL_MS = 30;

  // ─── GLSL — Dither ────────────────────────────────────────────────────────

  const VERT_SRC = `
    attribute vec2 a_position;
    void main() { gl_Position = vec4(a_position, 0.0, 1.0); }
  `;

  const FRAG_SRC = `
    precision highp float;

    uniform sampler2D u_source;
    uniform sampler2D u_atlas;
    uniform vec2 u_resolution;
    uniform float u_cellSize;
    uniform float u_glyphCount;
    uniform vec3 u_textColor;
    uniform vec3 u_bgColor;
    uniform vec3 u_accentColor;
    uniform float u_contrast;
    uniform float u_gamma;
    uniform float u_bias;
    uniform float u_edgeSoftness;
    uniform float u_foreground;
    uniform float u_midtone;
    uniform float u_background;
    uniform float u_noise;

    float smstep(float e0, float e1, float x) {
      float t = clamp((x - e0) / (e1 - e0), 0.0, 1.0);
      return t * t * (3.0 - 2.0 * t);
    }

    float noisehash(float x, float y) {
      return fract(sin(x * 12.9898 + y * 78.233) * 43758.5453);
    }

    void main() {
      vec2 fragPos = gl_FragCoord.xy;
      vec2 cellIdx = floor(fragPos / u_cellSize);
      vec2 withinCell = fract(fragPos / u_cellSize);
      vec2 base = cellIdx * u_cellSize;
      float sOff = u_cellSize / 5.0;

      vec2 cov2 = vec2(0.0);
      cov2 += texture2D(u_source, (base + vec2(1.0,1.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(2.0,1.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(3.0,1.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(4.0,1.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(1.0,2.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(2.0,2.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(3.0,2.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(4.0,2.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(1.0,3.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(2.0,3.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(3.0,3.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(4.0,3.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(1.0,4.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(2.0,4.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(3.0,4.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(4.0,4.0)*sOff) / u_resolution).rg;
      cov2 /= 16.0;
      float cov = max(cov2.x, cov2.y);

      if (u_noise > 0.0) {
        cov = clamp(cov + (noisehash(cellIdx.x, cellIdx.y) - 0.5) * u_noise, 0.0, 1.0);
      }

      cov = clamp(cov + u_bias, 0.0, 1.0);
      cov = pow(cov, u_gamma);
      cov = clamp((cov - 0.5) * u_contrast + 0.5, 0.0, 1.0);

      float se = u_edgeSoftness * 0.15;
      float br;
      if (cov < 0.05) {
        br = u_background;
      } else if (cov < 0.25) {
        float t = smstep(0.05 - se, 0.25 + se, cov);
        br = u_background + t * (u_midtone * 0.5 - u_background);
      } else if (cov < 0.5) {
        float t = smstep(0.25 - se, 0.5 + se, cov);
        br = u_midtone * 0.5 + t * (u_midtone * 0.5);
      } else if (cov < 0.75) {
        float t = smstep(0.5 - se, 0.75 + se, cov);
        br = u_midtone + t * (u_foreground * 0.85 - u_midtone);
      } else {
        float t = smstep(0.75 - se, 1.0, cov);
        br = u_foreground * 0.85 + t * (u_foreground * 0.15);
      }

      float gi = clamp(floor(cov * u_glyphCount), 0.0, u_glyphCount - 1.0);
      vec2 sc = clamp(withinCell, 0.5 / u_cellSize, 1.0 - 0.5 / u_cellSize);
      vec2 atlasUV = vec2((gi + sc.x) / u_glyphCount, sc.y);
      float mask = texture2D(u_atlas, atlasUV).r;

      float fringeAmount = clamp((cov2.y - cov2.x) / max(cov, 0.0001), 0.0, 1.0);
      fringeAmount = clamp(fringeAmount * 2.0, 0.0, 1.0);
      vec3 baseColor = mix(u_textColor, u_accentColor, fringeAmount);
      vec3 colInside = mix(u_bgColor, baseColor, clamp(br, 0.0, 1.0));
      vec3 col = mix(u_bgColor, colInside, mask);
      gl_FragColor = vec4(col, 1.0);
    }
  `;

  // ─── GLSL — Ripple pre-pass ───────────────────────────────────────────────

  const RIPPLE_LOOP = `
    vec2 disp = vec2(0.0);
    for (int i = 0; i < 16; i++) {
      if (i >= u_rippleCount) break;
      vec4 r = u_ripples[i];
      vec2 vel = u_rippleVel[i];
      vec2 to = uv - r.xy;
      float d = length(to);
      float pulse = exp(-(d * d) / max(u_thickness * u_thickness, 1e-6));
      float lifeT = clamp(r.z / u_lifetime, 0.0, 1.0);
      float decay = lifeT >= 1.0 ? 0.0 : pow(1.0 - lifeT, 2.0);
      vec2 dirRadial = d > 0.0001 ? -to / d : vec2(0.0);
      vec2 combined = mix(dirRadial, vel, u_directionality);
      float ang = atan(to.y, to.x);
      float phase = fract(sin(dot(r.xy, vec2(127.1, 311.7))) * 43758.5453) * 6.28318;
      float lobe = cos(ang * 3.0 + phase);
      float irregFactor = 1.0 + u_irregularity * lobe;
      disp += combined * pulse * decay * r.w * u_strength * irregFactor;
    }
  `;

  const PRE_FRAG = `
    precision highp float;
    uniform sampler2D u_srcRaw;
    uniform vec4 u_ripples[16];
    uniform vec2 u_rippleVel[16];
    uniform int u_rippleCount;
    uniform float u_strength;
    uniform float u_thickness;
    uniform float u_lifetime;
    uniform float u_chromatic;
    uniform float u_directionality;
    uniform float u_irregularity;
    uniform vec2 u_resolution;
    uniform float u_maxDisp;

    void main() {
      vec2 uv = gl_FragCoord.xy / u_resolution;
      ${RIPPLE_LOOP}
      vec2 maxDispUV = vec2(u_maxDisp) / u_resolution;
      disp = clamp(disp, -maxDispUV, maxDispUV);
      float main = texture2D(u_srcRaw, uv + disp).r;
      float ghost = texture2D(u_srcRaw, uv + disp * (1.0 + u_chromatic)).r;
      gl_FragColor = vec4(main, ghost, 0.0, 1.0);
    }
  `;

  // ─── Helpers ──────────────────────────────────────────────────────────────

  // Colors are read from CSS custom properties set on the component root via
  // Sass tokens (the project's documented "valores dinámicos por JS" exception)
  // — not from document.documentElement, since there is no global theme toggle.
  function getThemeColors(root: HTMLElement): { text: string; bg: string; accent: string } {
    const cs = getComputedStyle(root);
    const text = cs.getPropertyValue("--color-text").trim() || "#f7f7f7";
    const bg = cs.getPropertyValue("--color-bg").trim() || "#080808";
    const accent = cs.getPropertyValue("--color-accent").trim() || "#ffab6c";
    return { text, bg, accent };
  }

  function parseCssColor(value: string): [number, number, number] {
    const v = value.trim();
    const hex = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(v);
    if (hex) {
      return [
        parseInt(hex[1], 16) / 255,
        parseInt(hex[2], 16) / 255,
        parseInt(hex[3], 16) / 255,
      ];
    }
    const rgb = /rgba?\(\s*(\d+(?:\.\d+)?)\s*,\s*(\d+(?:\.\d+)?)\s*,\s*(\d+(?:\.\d+)?)/i.exec(v);
    if (rgb) {
      return [parseFloat(rgb[1]) / 255, parseFloat(rgb[2]) / 255, parseFloat(rgb[3]) / 255];
    }
    return [1, 1, 1];
  }

  function getSourceLines(root: HTMLElement): string[] {
    const el = root.querySelector<HTMLElement>("h1");
    if (!el) return [];
    return el.innerText.split("\n").map((l) => l.trim()).filter(Boolean);
  }

  // ─── WebGL utilities ──────────────────────────────────────────────────────

  function compileShader(gl: WebGLRenderingContext, type: number, src: string): WebGLShader | null {
    const s = gl.createShader(type);
    if (!s) return null;
    gl.shaderSource(s, src);
    gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
      console.error("Shader error:", gl.getShaderInfoLog(s));
      gl.deleteShader(s);
      return null;
    }
    return s;
  }

  function buildProgramFromSrc(
    gl: WebGLRenderingContext,
    vs: string,
    fs: string,
  ): WebGLProgram | null {
    const vert = compileShader(gl, gl.VERTEX_SHADER, vs);
    const frag = compileShader(gl, gl.FRAGMENT_SHADER, fs);
    if (!vert || !frag) return null;
    const prog = gl.createProgram()!;
    gl.attachShader(prog, vert);
    gl.attachShader(prog, frag);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      console.error("Program link error:", gl.getProgramInfoLog(prog));
      return null;
    }
    return prog;
  }

  function makeTexture(gl: WebGLRenderingContext): WebGLTexture | null {
    const tex = gl.createTexture();
    if (!tex) return null;
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    return tex;
  }

  function uploadTexture(
    gl: WebGLRenderingContext,
    tex: WebGLTexture,
    unit: number,
    canvas: HTMLCanvasElement,
  ) {
    gl.activeTexture(gl.TEXTURE0 + unit);
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, 1);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, canvas);
  }

  type FBO = { fbo: WebGLFramebuffer; tex: WebGLTexture; w: number; h: number };

  function makeFBO(gl: WebGLRenderingContext, w: number, h: number): FBO | null {
    const tex = gl.createTexture();
    const fbo = gl.createFramebuffer();
    if (!tex || !fbo) return null;
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, 0);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, w, h, 0, gl.RGBA, gl.UNSIGNED_BYTE, null);
    gl.bindFramebuffer(gl.FRAMEBUFFER, fbo);
    gl.framebufferTexture2D(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.TEXTURE_2D, tex, 0);
    const status = gl.checkFramebufferStatus(gl.FRAMEBUFFER);
    gl.bindFramebuffer(gl.FRAMEBUFFER, null);
    if (status !== gl.FRAMEBUFFER_COMPLETE) {
      gl.deleteTexture(tex);
      gl.deleteFramebuffer(fbo);
      return null;
    }
    return { fbo, tex, w, h };
  }

  function resizeFBO(gl: WebGLRenderingContext, fbo: FBO, w: number, h: number): FBO {
    if (fbo.w === w && fbo.h === h) return fbo;
    gl.bindTexture(gl.TEXTURE_2D, fbo.tex);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, w, h, 0, gl.RGBA, gl.UNSIGNED_BYTE, null);
    fbo.w = w;
    fbo.h = h;
    return fbo;
  }

  // ─── Canvas rendering ─────────────────────────────────────────────────────

  function wrapLine(ctx: CanvasRenderingContext2D, text: string, maxWidth: number): string[] {
    const words = text.split(/\s+/).filter(Boolean);
    if (words.length === 0) return [];
    const out: string[] = [];
    let current = words[0];
    for (let i = 1; i < words.length; i++) {
      const candidate = `${current} ${words[i]}`;
      if (ctx.measureText(candidate).width <= maxWidth) {
        current = candidate;
      } else {
        out.push(current);
        current = words[i];
      }
    }
    out.push(current);
    return out;
  }

  function renderSource(
    canvas: HTMLCanvasElement,
    lines: string[],
    w: number,
    h: number,
    fontFamily: string,
    fontWeight: string,
    computedFontSize: number,
    fontScale: number,
  ) {
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext("2d")!;
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, w, h);
    if (lines.length === 0 || computedFontSize <= 0) return;
    const fontSize = computedFontSize * fontScale;
    const lineHeight = fontSize * 0.92;
    ctx.fillStyle = "#fff";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.font = `${fontWeight} ${fontSize}px ${fontFamily}`;
    const WRAP_INSET = 0.98;
    const wrapped = lines.flatMap((line) => wrapLine(ctx, line, w * WRAP_INSET));
    if (wrapped.length === 0) return;
    const totalH = (wrapped.length - 1) * lineHeight;
    const startY = h * 0.5 - totalH * 0.5;
    wrapped.forEach((line, i) => ctx.fillText(line, w * 0.5, startY + i * lineHeight));
  }

  function buildAtlas(glyphs: string, cellSize: number, glyphScale: number): HTMLCanvasElement {
    const n = glyphs.length;
    const c = document.createElement("canvas");
    c.width = Math.max(1, n * cellSize);
    c.height = Math.max(1, cellSize);
    const ctx = c.getContext("2d")!;
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, c.width, c.height);
    ctx.fillStyle = "#fff";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.font = `${Math.max(1, Math.round(cellSize * glyphScale))}px "Geist Mono", "SF Mono", Monaco, monospace`;
    for (let i = 0; i < n; i++) {
      ctx.save();
      ctx.beginPath();
      ctx.rect(i * cellSize, 0, cellSize, cellSize);
      ctx.clip();
      ctx.fillText(glyphs[i], i * cellSize + cellSize * 0.5, cellSize * 0.5);
      ctx.restore();
    }
    return c;
  }

  // ─── Main ─────────────────────────────────────────────────────────────────

  function initGlyphDither() {
    const root = document.querySelector<HTMLElement>("[data-glyph-dither]");
    const glCanvas = root?.querySelector<HTMLCanvasElement>("[data-glyph-output]");
    if (!root || !glCanvas || root.dataset.bound === "true") return;

    const gl = glCanvas.getContext("webgl", { premultipliedAlpha: false });
    if (!gl) {
      console.warn("WebGL not supported");
      return;
    }

    const ditherProg = buildProgramFromSrc(gl, VERT_SRC, FRAG_SRC);
    const dispProg = buildProgramFromSrc(gl, VERT_SRC, PRE_FRAG);
    if (!ditherProg || !dispProg) return;

    const quadBuf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, quadBuf);
    gl.bufferData(
      gl.ARRAY_BUFFER,
      new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]),
      gl.STATIC_DRAW,
    );

    function bindQuad(prog: WebGLProgram) {
      const loc = gl!.getAttribLocation(prog, "a_position");
      gl!.bindBuffer(gl!.ARRAY_BUFFER, quadBuf);
      gl!.enableVertexAttribArray(loc);
      gl!.vertexAttribPointer(loc, 2, gl!.FLOAT, false, 0, 0);
    }

    const srcRawTex = makeTexture(gl)!;
    const atlasTex = makeTexture(gl)!;

    gl.useProgram(ditherProg);
    bindQuad(ditherProg);
    gl.uniform1i(gl.getUniformLocation(ditherProg, "u_source"), 0);
    gl.uniform1i(gl.getUniformLocation(ditherProg, "u_atlas"), 1);

    const dLoc = {
      res: gl.getUniformLocation(ditherProg, "u_resolution"),
      cell: gl.getUniformLocation(ditherProg, "u_cellSize"),
      glyphs: gl.getUniformLocation(ditherProg, "u_glyphCount"),
      text: gl.getUniformLocation(ditherProg, "u_textColor"),
      bg: gl.getUniformLocation(ditherProg, "u_bgColor"),
      accent: gl.getUniformLocation(ditherProg, "u_accentColor"),
      contrast: gl.getUniformLocation(ditherProg, "u_contrast"),
      gamma: gl.getUniformLocation(ditherProg, "u_gamma"),
      bias: gl.getUniformLocation(ditherProg, "u_bias"),
      edge: gl.getUniformLocation(ditherProg, "u_edgeSoftness"),
      fg: gl.getUniformLocation(ditherProg, "u_foreground"),
      mid: gl.getUniformLocation(ditherProg, "u_midtone"),
      bgOp: gl.getUniformLocation(ditherProg, "u_background"),
      noise: gl.getUniformLocation(ditherProg, "u_noise"),
    };

    const dispLoc = {
      srcRaw: gl.getUniformLocation(dispProg, "u_srcRaw"),
      ripples: gl.getUniformLocation(dispProg, "u_ripples"),
      vel: gl.getUniformLocation(dispProg, "u_rippleVel"),
      count: gl.getUniformLocation(dispProg, "u_rippleCount"),
      strength: gl.getUniformLocation(dispProg, "u_strength"),
      thickness: gl.getUniformLocation(dispProg, "u_thickness"),
      lifetime: gl.getUniformLocation(dispProg, "u_lifetime"),
      chromatic: gl.getUniformLocation(dispProg, "u_chromatic"),
      directionality: gl.getUniformLocation(dispProg, "u_directionality"),
      irregularity: gl.getUniformLocation(dispProg, "u_irregularity"),
      res: gl.getUniformLocation(dispProg, "u_resolution"),
      maxDisp: gl.getUniformLocation(dispProg, "u_maxDisp"),
    };
    gl.useProgram(dispProg);
    gl.uniform1i(dispLoc.srcRaw, 2);

    // ── State ───────────────────────────────────────────────────────────────
    const sourceCanvas = document.createElement("canvas");
    let atlasKey = "";
    let lastW = 0;
    let lastH = 0;
    const params: Params = { ...DEFAULT_PARAMS };
    let raf = 0;
    let pendingKickFrames = 0;
    let displaced: FBO | null = null;

    // Static dark theme → read the palette once from the root's CSS vars.
    const theme = getThemeColors(root);
    const textRGB = parseCssColor(theme.text);
    const bgRGB = parseCssColor(theme.bg);
    const accentRGB = parseCssColor(theme.accent);
    let rippleAvailable = false;

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    // Displacement is computed in UV space, so a narrower viewport yields fewer
    // pixels of warp — touch devices feel weaker. Boost strength + raise the
    // clamp on coarse pointers so phones get equal/stronger deformation.
    const coarsePointer = window.matchMedia("(pointer: coarse)").matches;
    const COARSE_STRENGTH = 3.5;
    const COARSE_MAX_DISP = 50;
    const FINE_MAX_DISP = 30;

    type Ripple = { x: number; y: number; bornAt: number; amp: number; vx: number; vy: number };
    const ripples: Ripple[] = [];
    const ripplePack = new Float32Array(MAX_RIPPLES * 4);
    const rippleVelPack = new Float32Array(MAX_RIPPLES * 2);
    let lastRippleX = 0;
    let lastRippleY = 0;
    let lastRippleAt = 0;
    let prevMouseX = -1;
    let prevMouseY = -1;

    function rippleParams() {
      const trail = Math.max(0, Math.min(1, params.rippleTrail / 100));
      return {
        strength: (params.rippleStrength / 100) * 0.025 * (coarsePointer ? COARSE_STRENGTH : 1),
        thickness: Math.max(0.005, 0.04 - (params.rippleScale / 100) * 0.025),
        lifetime: (0.2 + (params.rippleViscosity / 100) * 0.4) * (1 + trail * 2),
        chromatic: Math.min(1.5, (params.rippleChromatic / 100) * 1.0),
        directionality: Math.max(0, Math.min(1, params.rippleDirectionality / 100)),
        irregularity: Math.max(0, Math.min(1, params.rippleIrregularity / 100)),
        minDistancePx: MIN_DISTANCE_PX * (1 - trail * 0.7),
        minIntervalMs: MIN_INTERVAL_MS * (1 - trail * 0.7),
      };
    }

    function ensureSize(): boolean {
      const rect = root!.getBoundingClientRect();
      const w = Math.floor(rect.width);
      const h = Math.floor(rect.height);
      if (w <= 0 || h <= 0) return false;
      if (glCanvas!.width !== w || glCanvas!.height !== h) {
        glCanvas!.width = w;
        glCanvas!.height = h;
      }
      lastW = w;
      lastH = h;

      if (!displaced) {
        displaced = makeFBO(gl!, w, h);
        rippleAvailable = !!displaced;
      } else {
        displaced = resizeFBO(gl!, displaced, w, h);
      }
      return true;
    }

    function uploadSource() {
      const lines = getSourceLines(root!);
      const headline = root!.querySelector<HTMLElement>("h1");
      const hs = headline ? getComputedStyle(headline) : null;
      const fontFamily = hs?.fontFamily || `"Geist Mono", monospace`;
      const fontWeight = hs?.fontWeight || "400";
      const computedFontSize = hs ? parseFloat(hs.fontSize) : 64;
      renderSource(
        sourceCanvas,
        lines,
        lastW,
        lastH,
        fontFamily,
        fontWeight,
        computedFontSize,
        params.fontScale,
      );
      uploadTexture(gl!, srcRawTex, 2, sourceCanvas);
      return computedFontSize;
    }

    function ensureAtlas(effectiveCellSize: number) {
      const glyphs = GLYPH_PRESETS[params.preset] || GLYPH_PRESETS.default;
      const newAtlasKey = `${params.preset}:${effectiveCellSize}:${params.glyphScale}`;
      if (newAtlasKey !== atlasKey) {
        const atlas = buildAtlas(glyphs, effectiveCellSize, params.glyphScale);
        uploadTexture(gl!, atlasTex, 1, atlas);
        atlasKey = newAtlasKey;
      }
      return glyphs;
    }

    function packRipples(now: number) {
      const lifetime = rippleParams().lifetime;
      let w = 0;
      for (let i = 0; i < ripples.length; i++) {
        const age = (now - ripples[i].bornAt) / 1000;
        if (age < lifetime) {
          if (w !== i) ripples[w] = ripples[i];
          w++;
        }
      }
      ripples.length = w;
      ripplePack.fill(0);
      rippleVelPack.fill(0);
      for (let i = 0; i < ripples.length && i < MAX_RIPPLES; i++) {
        const r = ripples[i];
        const age = (now - r.bornAt) / 1000;
        ripplePack[i * 4 + 0] = r.x;
        ripplePack[i * 4 + 1] = r.y;
        ripplePack[i * 4 + 2] = age;
        ripplePack[i * 4 + 3] = r.amp;
        rippleVelPack[i * 2 + 0] = r.vx;
        rippleVelPack[i * 2 + 1] = r.vy;
      }
    }

    function setRippleUniforms() {
      const rp = rippleParams();
      gl!.uniform4fv(dispLoc.ripples, ripplePack);
      gl!.uniform2fv(dispLoc.vel, rippleVelPack);
      gl!.uniform1i(dispLoc.count, ripples.length);
      gl!.uniform1f(dispLoc.strength, rp.strength);
      gl!.uniform1f(dispLoc.thickness, rp.thickness);
      gl!.uniform1f(dispLoc.lifetime, rp.lifetime);
      gl!.uniform1f(dispLoc.chromatic, rp.chromatic);
      gl!.uniform1f(dispLoc.directionality, rp.directionality);
      gl!.uniform1f(dispLoc.irregularity, rp.irregularity);
      gl!.uniform1f(dispLoc.maxDisp, coarsePointer ? COARSE_MAX_DISP : FINE_MAX_DISP);
    }

    function runPrePass() {
      if (!displaced) return;
      gl!.useProgram(dispProg!);
      bindQuad(dispProg!);
      gl!.bindFramebuffer(gl!.FRAMEBUFFER, displaced.fbo);
      gl!.viewport(0, 0, lastW, lastH);
      gl!.activeTexture(gl!.TEXTURE2);
      gl!.bindTexture(gl!.TEXTURE_2D, srcRawTex);
      gl!.uniform2f(dispLoc.res, lastW, lastH);
      setRippleUniforms();
      gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
    }

    function runDither(sourceTex: WebGLTexture) {
      // Fixed cell size: the glyph grid no longer scales with the font, so the
      // "404" can grow without enlarging the cells/glyphs.
      const effectiveCellSize = Math.max(2, params.cellSize);
      const glyphs = ensureAtlas(effectiveCellSize);

      gl!.useProgram(ditherProg!);
      bindQuad(ditherProg!);
      gl!.bindFramebuffer(gl!.FRAMEBUFFER, null);
      gl!.viewport(0, 0, lastW, lastH);

      gl!.activeTexture(gl!.TEXTURE0);
      gl!.bindTexture(gl!.TEXTURE_2D, sourceTex);
      gl!.activeTexture(gl!.TEXTURE1);
      gl!.bindTexture(gl!.TEXTURE_2D, atlasTex);

      gl!.uniform2f(dLoc.res, lastW, lastH);
      gl!.uniform1f(dLoc.cell, effectiveCellSize);
      gl!.uniform1f(dLoc.glyphs, glyphs.length);
      gl!.uniform3f(dLoc.text, textRGB[0], textRGB[1], textRGB[2]);
      gl!.uniform3f(dLoc.bg, bgRGB[0], bgRGB[1], bgRGB[2]);
      gl!.uniform3f(dLoc.accent, accentRGB[0], accentRGB[1], accentRGB[2]);
      gl!.uniform1f(dLoc.contrast, params.contrast);
      gl!.uniform1f(dLoc.gamma, params.gamma);
      gl!.uniform1f(dLoc.bias, params.thresholdBias);
      gl!.uniform1f(dLoc.edge, params.edgeSoftness);
      gl!.uniform1f(dLoc.fg, params.foregroundBrightness);
      gl!.uniform1f(dLoc.mid, params.midtoneBrightness);
      gl!.uniform1f(dLoc.bgOp, params.backgroundOpacity);
      gl!.uniform1f(dLoc.noise, params.noiseAmount);
      gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
    }

    function frame() {
      if (!ensureSize()) {
        raf = 0;
        return;
      }
      uploadSource();

      const now = performance.now();
      packRipples(now);

      if (rippleAvailable) {
        runPrePass();
        runDither(displaced!.tex);
      } else {
        runDither(srcRawTex);
      }

      if (pendingKickFrames > 0) pendingKickFrames--;
      if (ripples.length > 0 || pendingKickFrames > 0) {
        raf = requestAnimationFrame(frame);
      } else {
        raf = 0;
      }
    }

    function kick(frames: number = 2) {
      if (frames > pendingKickFrames) pendingKickFrames = frames;
      if (!raf) raf = requestAnimationFrame(frame);
    }

    // Shared by mouse and touch: emit a ripple from a viewport-space point.
    function emitFromPoint(clientX: number, clientY: number) {
      if (prefersReduced || !rippleAvailable) return;
      const rect = root!.getBoundingClientRect();
      const x = clientX - rect.left;
      const y = clientY - rect.top;
      const now = performance.now();

      let dx = 0;
      let dy = 0;
      let mag = 0;
      if (prevMouseX >= 0) {
        dx = x - prevMouseX;
        dy = y - prevMouseY;
        mag = Math.hypot(dx, dy);
      }
      prevMouseX = x;
      prevMouseY = y;

      if (mag < 0.5) return;

      const rp = rippleParams();
      const distFromLast =
        lastRippleAt === 0 ? Infinity : Math.hypot(x - lastRippleX, y - lastRippleY);
      const dtFromLast = now - lastRippleAt;
      const shouldEmit =
        lastRippleAt === 0 ||
        distFromLast >= rp.minDistancePx ||
        dtFromLast >= rp.minIntervalMs;
      if (!shouldEmit) return;

      const momentumFactor = (params.rippleMomentum / 100) * 3.0;
      const amp = Math.max(0.05, Math.min(1, mag * momentumFactor * 0.01));
      const u = Math.max(0, Math.min(1, x / Math.max(1, rect.width)));
      const v = Math.max(0, Math.min(1, 1 - y / Math.max(1, rect.height)));
      const invMag = mag > 0 ? 1 / mag : 0;
      const vx = dx * invMag;
      const vy = -dy * invMag;

      if (ripples.length >= MAX_RIPPLES) ripples.shift();
      ripples.push({ x: u, y: v, bornAt: now, amp, vx, vy });
      lastRippleX = x;
      lastRippleY = y;
      lastRippleAt = now;

      if (!raf) raf = requestAnimationFrame(frame);
    }

    function onMouseMove(e: MouseEvent) {
      emitFromPoint(e.clientX, e.clientY);
    }

    function resetVelocity() {
      prevMouseX = -1;
      prevMouseY = -1;
    }

    // Touch = the mobile equivalent of hover: dragging a finger emits ripples.
    function onTouchStart(e: TouchEvent) {
      const t = e.touches[0];
      if (!t) return;
      // Seed prev* at the start point so the first touchmove computes velocity
      // without a huge jump from a stale position.
      const rect = root!.getBoundingClientRect();
      prevMouseX = t.clientX - rect.left;
      prevMouseY = t.clientY - rect.top;
    }

    function onTouchMove(e: TouchEvent) {
      const t = e.touches[0];
      if (t) emitFromPoint(t.clientX, t.clientY);
    }

    root.addEventListener("mousemove", onMouseMove);
    root.addEventListener("mouseleave", resetVelocity);
    // passive: the 404 doesn't scroll, so no preventDefault is needed
    root.addEventListener("touchstart", onTouchStart, { passive: true });
    root.addEventListener("touchmove", onTouchMove, { passive: true });
    root.addEventListener("touchend", resetVelocity);
    root.addEventListener("touchcancel", resetVelocity);

    const onResize = () => kick();
    window.addEventListener("resize", onResize);
    document.fonts.ready.then(() => kick());

    kick();

    root.dataset.bound = "true";
  }

  if (document.readyState !== "loading") {
    initGlyphDither();
  } else {
    document.addEventListener("DOMContentLoaded", initGlyphDither, { once: true });
  }
</script>
