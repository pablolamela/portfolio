---
import styles from "./HeroGlyphDither.module.scss";
---

<div class={styles.root} data-glyph-dither>
  <canvas class={styles.output} data-glyph-output aria-hidden="true"></canvas>

  <button class={styles.toggle} type="button" data-glyph-toggle aria-expanded="false">
    Glyph knobs
  </button>

  <form class={styles.controls} data-glyph-controls hidden>
    <label>
      Preset
      <select name="preset">
        <option value="ascii">ASCII</option>
        <option value="default">Default</option>
        <option value="blocks">Blocks</option>
        <option value="braille">Braille</option>
      </select>
    </label>

    <label>
      Cell
      <input name="cellSize" type="range" min="4" max="16" step="1" />
      <output data-output-for="cellSize"></output>
    </label>

    <label>
      Font
      <input name="fontScale" type="range" min="0.45" max="1.2" step="0.01" />
      <output data-output-for="fontScale"></output>
    </label>

    <label>
      Edge
      <input name="edgeSoftness" type="range" min="0" max="1" step="0.01" />
      <output data-output-for="edgeSoftness"></output>
    </label>

    <label>
      Foreground
      <input name="foregroundBrightness" type="range" min="0" max="1.5" step="0.01" />
      <output data-output-for="foregroundBrightness"></output>
    </label>

    <label>
      Midtone
      <input name="midtoneBrightness" type="range" min="0" max="1.2" step="0.01" />
      <output data-output-for="midtoneBrightness"></output>
    </label>

    <label>
      Background
      <input name="backgroundOpacity" type="range" min="0" max="0.12" step="0.005" />
      <output data-output-for="backgroundOpacity"></output>
    </label>

    <label>
      Contrast
      <input name="contrast" type="range" min="0.2" max="3" step="0.01" />
      <output data-output-for="contrast"></output>
    </label>

    <label>
      Bias
      <input name="thresholdBias" type="range" min="-0.5" max="0.5" step="0.01" />
      <output data-output-for="thresholdBias"></output>
    </label>

    <label>
      Gamma
      <input name="gamma" type="range" min="0.2" max="3" step="0.01" />
      <output data-output-for="gamma"></output>
    </label>

    <label>
      Noise
      <input name="noiseAmount" type="range" min="0" max="0.6" step="0.01" />
      <output data-output-for="noiseAmount"></output>
    </label>

    <label>
      Color
      <input name="textColor" type="color" />
    </label>

    <label>
      Background
      <input name="backgroundColor" type="color" />
    </label>

    <button type="button" data-copy-params>Copy params</button>
    <textarea data-params-output readonly rows="7" spellcheck="false"></textarea>
  </form>
</div>

<script>
  const GLYPH_PRESETS = {
    default: " .:-=+*#%@",
    blocks: " ░▒▓█",
    ascii:
      " `.-':_,^=;><+!rc*/z?sLTv)J7(|Fi{C}fI31tlu[neoZ5Yxjya]2ESwqkP6h9d4VpOGbUAKXHm8RD#$Bg0MNWQ%&@",
    braille:
      " ⠁⠂⠃⠄⠅⠆⠇⠈⠉⠊⠋⠌⠍⠎⠏⠐⠑⠒⠓⠔⠕⠖⠗⠘⠙⠚⠛⠜⠝⠞⠟⠠⠡⠢⠣⠤⠥⠦⠧⠨⠩⠪⠫⠬⠭⠮⠯⠰⠱⠲⠳⠴⠵⠶⠷⠸⠹⠺⠻⠼⠽⠾⠿",
  } as const;

  const DEFAULT_PARAMS = {
    preset: "default",
    cellSize: 8,
    fontScale: 1,
    textColor: "#ffffff",
    backgroundColor: "#000000",
    edgeSoftness: 0.36,
    foregroundBrightness: 1,
    midtoneBrightness: 0.62,
    backgroundOpacity: 0,
    contrast: 1.7,
    thresholdBias: -0.02,
    gamma: 0.82,
    noiseAmount: 0,
  };

  type Params = typeof DEFAULT_PARAMS;

  // ─── GLSL ─────────────────────────────────────────────────────────────────

  const VERT_SRC = `
    attribute vec2 a_position;
    void main() { gl_Position = vec4(a_position, 0.0, 1.0); }
  `;

  // 4×4 coverage samples unrolled for WebGL 1 compatibility
  const FRAG_SRC = `
    precision highp float;

    uniform sampler2D u_source;
    uniform sampler2D u_atlas;
    uniform vec2 u_resolution;
    uniform float u_cellSize;
    uniform float u_glyphCount;
    uniform vec3 u_textColor;
    uniform vec3 u_bgColor;
    uniform float u_contrast;
    uniform float u_gamma;
    uniform float u_bias;
    uniform float u_edgeSoftness;
    uniform float u_foreground;
    uniform float u_midtone;
    uniform float u_background;
    uniform float u_noise;

    float smstep(float e0, float e1, float x) {
      float t = clamp((x - e0) / (e1 - e0), 0.0, 1.0);
      return t * t * (3.0 - 2.0 * t);
    }

    float noisehash(float x, float y) {
      return fract(sin(x * 12.9898 + y * 78.233) * 43758.5453);
    }

    void main() {
      vec2 fragPos = gl_FragCoord.xy;
      vec2 cellIdx = floor(fragPos / u_cellSize);
      vec2 withinCell = fract(fragPos / u_cellSize);
      vec2 base = cellIdx * u_cellSize;
      float sOff = u_cellSize / 5.0;

      float cov = 0.0;
      cov += texture2D(u_source, (base + vec2(1.0,1.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(2.0,1.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(3.0,1.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(4.0,1.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(1.0,2.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(2.0,2.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(3.0,2.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(4.0,2.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(1.0,3.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(2.0,3.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(3.0,3.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(4.0,3.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(1.0,4.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(2.0,4.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(3.0,4.0)*sOff) / u_resolution).r;
      cov += texture2D(u_source, (base + vec2(4.0,4.0)*sOff) / u_resolution).r;
      cov /= 16.0;

      if (u_noise > 0.0) {
        cov = clamp(cov + (noisehash(cellIdx.x, cellIdx.y) - 0.5) * u_noise, 0.0, 1.0);
      }

      cov = clamp(cov + u_bias, 0.0, 1.0);
      cov = pow(cov, u_gamma);
      cov = clamp((cov - 0.5) * u_contrast + 0.5, 0.0, 1.0);

      float se = u_edgeSoftness * 0.15;
      float br;
      if (cov < 0.05) {
        br = u_background;
      } else if (cov < 0.25) {
        float t = smstep(0.05 - se, 0.25 + se, cov);
        br = u_background + t * (u_midtone * 0.5 - u_background);
      } else if (cov < 0.5) {
        float t = smstep(0.25 - se, 0.5 + se, cov);
        br = u_midtone * 0.5 + t * (u_midtone * 0.5);
      } else if (cov < 0.75) {
        float t = smstep(0.5 - se, 0.75 + se, cov);
        br = u_midtone + t * (u_foreground * 0.85 - u_midtone);
      } else {
        float t = smstep(0.75 - se, 1.0, cov);
        br = u_foreground * 0.85 + t * (u_foreground * 0.15);
      }

      float gi = clamp(floor(cov * u_glyphCount), 0.0, u_glyphCount - 1.0);
      // clamp withinCell away from edges to prevent glyph bleeding with LINEAR filter
      vec2 sc = clamp(withinCell, 0.5 / u_cellSize, 1.0 - 0.5 / u_cellSize);
      vec2 atlasUV = vec2((gi + sc.x) / u_glyphCount, sc.y);
      float mask = texture2D(u_atlas, atlasUV).r;

      vec3 col = u_bgColor + (u_textColor * br - u_bgColor) * mask;
      gl_FragColor = vec4(col, 1.0);
    }
  `;

  // ─── Helpers ──────────────────────────────────────────────────────────────

  function parseHex(hex: string): [number, number, number] {
    const r = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return r
      ? [parseInt(r[1], 16) / 255, parseInt(r[2], 16) / 255, parseInt(r[3], 16) / 255]
      : [1, 1, 1];
  }

  function getHeadlineLines(): string[] {
    const el = document.querySelector<HTMLElement>("[data-hero-section] h1");
    if (!el) return [];
    return el.innerText.split("\n").map((l) => l.trim()).filter(Boolean);
  }

  function numberParam(form: HTMLFormElement, name: keyof Params): number {
    const el = form.elements.namedItem(String(name)) as HTMLInputElement | null;
    return el ? parseFloat(el.value) : Number(DEFAULT_PARAMS[name]);
  }

  function getParams(form: HTMLFormElement): Params {
    const preset = (form.elements.namedItem("preset") as HTMLSelectElement | null)?.value;
    const textColor = (form.elements.namedItem("textColor") as HTMLInputElement | null)?.value;
    const backgroundColor = (
      form.elements.namedItem("backgroundColor") as HTMLInputElement | null
    )?.value;
    return {
      preset: (
        preset && preset in GLYPH_PRESETS ? preset : DEFAULT_PARAMS.preset
      ) as Params["preset"],
      cellSize: numberParam(form, "cellSize"),
      fontScale: numberParam(form, "fontScale"),
      textColor: textColor || DEFAULT_PARAMS.textColor,
      backgroundColor: backgroundColor || DEFAULT_PARAMS.backgroundColor,
      edgeSoftness: numberParam(form, "edgeSoftness"),
      foregroundBrightness: numberParam(form, "foregroundBrightness"),
      midtoneBrightness: numberParam(form, "midtoneBrightness"),
      backgroundOpacity: numberParam(form, "backgroundOpacity"),
      contrast: numberParam(form, "contrast"),
      thresholdBias: numberParam(form, "thresholdBias"),
      gamma: numberParam(form, "gamma"),
      noiseAmount: numberParam(form, "noiseAmount"),
    };
  }

  function applyParams(form: HTMLFormElement, params: Params) {
    Object.entries(params).forEach(([name, value]) => {
      const el = form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = String(value);
    });
  }

  function updateOutputs(form: HTMLFormElement) {
    form.querySelectorAll<HTMLOutputElement>("output[data-output-for]").forEach((out) => {
      const input = form.elements.namedItem(out.dataset.outputFor!) as HTMLInputElement | null;
      if (input) out.value = input.value;
    });
  }

  function serializeParams(params: Params): string {
    return JSON.stringify(params, null, 2);
  }

  // ─── WebGL utilities ──────────────────────────────────────────────────────

  function compileShader(gl: WebGLRenderingContext, type: number, src: string): WebGLShader | null {
    const s = gl.createShader(type);
    if (!s) return null;
    gl.shaderSource(s, src);
    gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
      console.error("Shader error:", gl.getShaderInfoLog(s));
      gl.deleteShader(s);
      return null;
    }
    return s;
  }

  function buildProgram(gl: WebGLRenderingContext): WebGLProgram | null {
    const vert = compileShader(gl, gl.VERTEX_SHADER, VERT_SRC);
    const frag = compileShader(gl, gl.FRAGMENT_SHADER, FRAG_SRC);
    if (!vert || !frag) return null;
    const prog = gl.createProgram()!;
    gl.attachShader(prog, vert);
    gl.attachShader(prog, frag);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      console.error("Program link error:", gl.getProgramInfoLog(prog));
      return null;
    }
    return prog;
  }

  function makeTexture(gl: WebGLRenderingContext): WebGLTexture | null {
    const tex = gl.createTexture();
    if (!tex) return null;
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    return tex;
  }

  function uploadTexture(
    gl: WebGLRenderingContext,
    tex: WebGLTexture,
    unit: number,
    canvas: HTMLCanvasElement,
  ) {
    gl.activeTexture(gl.TEXTURE0 + unit);
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, 1);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, canvas);
  }

  // ─── Canvas rendering ─────────────────────────────────────────────────────

  function renderSource(
    canvas: HTMLCanvasElement,
    lines: string[],
    w: number,
    h: number,
    fontFamily: string,
    fontWeight: string,
    computedFontSize: number,
    fontScale: number,
  ) {
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext("2d")!;
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, w, h);
    if (lines.length === 0 || computedFontSize <= 0) return;
    const fontSize = computedFontSize * fontScale;
    const lineHeight = fontSize * 0.92;
    const totalH = (lines.length - 1) * lineHeight;
    const startY = h * 0.5 - totalH * 0.5;
    ctx.fillStyle = "#fff";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.font = `${fontWeight} ${fontSize}px ${fontFamily}`;
    lines.forEach((line, i) => ctx.fillText(line, w * 0.5, startY + i * lineHeight));
  }

  function buildAtlas(glyphs: string, cellSize: number): HTMLCanvasElement {
    const n = glyphs.length;
    const c = document.createElement("canvas");
    c.width = Math.max(1, n * cellSize);
    c.height = Math.max(1, cellSize);
    const ctx = c.getContext("2d")!;
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, c.width, c.height);
    ctx.fillStyle = "#fff";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.font = `${Math.round(cellSize * 0.85)}px "Geist Mono","SF Mono",Monaco,monospace`;
    for (let i = 0; i < n; i++) {
      ctx.fillText(glyphs[i], i * cellSize + cellSize * 0.5, cellSize * 0.5);
    }
    return c;
  }

  // ─── Main ─────────────────────────────────────────────────────────────────

  function initGlyphDither() {
    const root = document.querySelector<HTMLElement>("[data-glyph-dither]");
    const glCanvas = root?.querySelector<HTMLCanvasElement>("[data-glyph-output]");
    const form = root?.querySelector<HTMLFormElement>("[data-glyph-controls]");
    const toggle = root?.querySelector<HTMLButtonElement>("[data-glyph-toggle]");
    const copyButton = root?.querySelector<HTMLButtonElement>("[data-copy-params]");
    if (!root || !glCanvas || !form || !toggle || root.dataset.bound === "true") return;

    const gl = glCanvas.getContext("webgl");
    if (!gl) {
      console.warn("WebGL not supported");
      return;
    }

    const prog = buildProgram(gl);
    if (!prog) return;
    gl.useProgram(prog);

    // Full-screen quad
    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(
      gl.ARRAY_BUFFER,
      new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]),
      gl.STATIC_DRAW,
    );
    const posLoc = gl.getAttribLocation(prog, "a_position");
    gl.enableVertexAttribArray(posLoc);
    gl.vertexAttribPointer(posLoc, 2, gl.FLOAT, false, 0, 0);

    // Textures — source on unit 0, atlas on unit 1
    const srcTex = makeTexture(gl)!;
    const atlasTex = makeTexture(gl)!;
    gl.uniform1i(gl.getUniformLocation(prog, "u_source"), 0);
    gl.uniform1i(gl.getUniformLocation(prog, "u_atlas"), 1);

    // Cache uniform locations
    const uLoc = {
      res: gl.getUniformLocation(prog, "u_resolution"),
      cell: gl.getUniformLocation(prog, "u_cellSize"),
      glyphs: gl.getUniformLocation(prog, "u_glyphCount"),
      text: gl.getUniformLocation(prog, "u_textColor"),
      bg: gl.getUniformLocation(prog, "u_bgColor"),
      contrast: gl.getUniformLocation(prog, "u_contrast"),
      gamma: gl.getUniformLocation(prog, "u_gamma"),
      bias: gl.getUniformLocation(prog, "u_bias"),
      edge: gl.getUniformLocation(prog, "u_edgeSoftness"),
      fg: gl.getUniformLocation(prog, "u_foreground"),
      mid: gl.getUniformLocation(prog, "u_midtone"),
      bgOp: gl.getUniformLocation(prog, "u_background"),
      noise: gl.getUniformLocation(prog, "u_noise"),
    };

    const sourceCanvas = document.createElement("canvas");
    let atlasKey = "";
    let frame = 0;
    let timer = 0;

    applyParams(form, DEFAULT_PARAMS);

    function render() {
      const params = getParams(form!);
      const lines = getHeadlineLines();
      const rect = root!.getBoundingClientRect();
      const w = Math.floor(rect.width);
      const h = Math.floor(rect.height);
      if (w <= 0 || h <= 0) return;

      if (glCanvas!.width !== w || glCanvas!.height !== h) {
        glCanvas!.width = w;
        glCanvas!.height = h;
      }

      const headline = document.querySelector<HTMLElement>("[data-hero-section] h1");
      const hs = headline ? getComputedStyle(headline) : null;
      const fontFamily = hs?.fontFamily || `"Geist Variable", system-ui, sans-serif`;
      const fontWeight = hs?.fontWeight || "400";
      const computedFontSize = hs ? parseFloat(hs.fontSize) : 64;

      renderSource(sourceCanvas, lines, w, h, fontFamily, fontWeight, computedFontSize, params.fontScale);
      uploadTexture(gl!, srcTex, 0, sourceCanvas);

      const glyphs = GLYPH_PRESETS[params.preset] || GLYPH_PRESETS.default;
      const newAtlasKey = `${params.preset}:${params.cellSize}`;
      if (newAtlasKey !== atlasKey) {
        const atlas = buildAtlas(glyphs, params.cellSize);
        uploadTexture(gl!, atlasTex, 1, atlas);
        atlasKey = newAtlasKey;
      }

      gl!.viewport(0, 0, w, h);
      gl!.uniform2f(uLoc.res, w, h);
      gl!.uniform1f(uLoc.cell, params.cellSize);
      gl!.uniform1f(uLoc.glyphs, glyphs.length);
      gl!.uniform3f(uLoc.text, ...parseHex(params.textColor));
      gl!.uniform3f(uLoc.bg, ...parseHex(params.backgroundColor));
      gl!.uniform1f(uLoc.contrast, params.contrast);
      gl!.uniform1f(uLoc.gamma, params.gamma);
      gl!.uniform1f(uLoc.bias, params.thresholdBias);
      gl!.uniform1f(uLoc.edge, params.edgeSoftness);
      gl!.uniform1f(uLoc.fg, params.foregroundBrightness);
      gl!.uniform1f(uLoc.mid, params.midtoneBrightness);
      gl!.uniform1f(uLoc.bgOp, params.backgroundOpacity);
      gl!.uniform1f(uLoc.noise, params.noiseAmount);
      gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);

      root!.style.backgroundColor = params.backgroundColor;
      const paramsOut = root!.querySelector<HTMLTextAreaElement>("[data-params-output]");
      if (paramsOut) paramsOut.value = serializeParams(params);
      updateOutputs(form!);
    }

    const scheduleRender = () => {
      if (frame) cancelAnimationFrame(frame);
      frame = requestAnimationFrame(render);
    };
    const scheduleDeferred = () => {
      window.clearTimeout(timer);
      timer = window.setTimeout(scheduleRender, 80);
      updateOutputs(form!);
    };

    toggle.addEventListener("click", () => {
      const hidden = form!.hidden;
      form!.hidden = !hidden;
      toggle.setAttribute("aria-expanded", String(hidden));
    });

    form.addEventListener("input", scheduleDeferred);
    form.addEventListener("change", scheduleRender);

    copyButton?.addEventListener("click", async () => {
      const value = serializeParams(getParams(form!));
      const out = root!.querySelector<HTMLTextAreaElement>("[data-params-output]");
      if (out) {
        out.value = value;
        out.select();
      }
      try {
        await navigator.clipboard.writeText(value);
      } catch {}
    });

    root.dataset.bound = "true";
    window.addEventListener("resize", scheduleRender);
    document.fonts.ready.then(scheduleRender);
  }

  document.addEventListener("astro:page-load", initGlyphDither);
  if (document.readyState !== "loading") {
    initGlyphDither();
  } else {
    document.addEventListener("DOMContentLoaded", initGlyphDither, { once: true });
  }
</script>
