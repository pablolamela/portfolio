---
import styles from "./HeroGlyphDither.module.scss";
---

<div class={styles.root} data-glyph-dither>
  <canvas class={styles.output} data-glyph-output aria-hidden="true"></canvas>

  <button class={styles.toggle} type="button" data-glyph-toggle aria-expanded="false">
    Glyph knobs
  </button>

  <form class={styles.controls} data-glyph-controls hidden>
    <label>
      Preset
      <select name="preset">
        <option value="ascii">ASCII</option>
        <option value="default">Default</option>
        <option value="blocks">Blocks</option>
        <option value="braille">Braille</option>
      </select>
    </label>

    <label>
      Cell
      <input name="cellSize" type="range" min="4" max="16" step="1" />
      <output data-output-for="cellSize"></output>
    </label>

    <label>
      Glyph
      <input name="glyphScale" type="range" min="0.4" max="1.4" step="0.01" />
      <output data-output-for="glyphScale"></output>
    </label>

    <label>
      Font
      <input name="fontScale" type="range" min="0.45" max="1.2" step="0.01" />
      <output data-output-for="fontScale"></output>
    </label>

    <label>
      Edge
      <input name="edgeSoftness" type="range" min="0" max="1" step="0.01" />
      <output data-output-for="edgeSoftness"></output>
    </label>

    <label>
      Foreground
      <input name="foregroundBrightness" type="range" min="0" max="1.5" step="0.01" />
      <output data-output-for="foregroundBrightness"></output>
    </label>

    <label>
      Midtone
      <input name="midtoneBrightness" type="range" min="0" max="1.2" step="0.01" />
      <output data-output-for="midtoneBrightness"></output>
    </label>

    <label>
      Background
      <input name="backgroundOpacity" type="range" min="0" max="0.12" step="0.005" />
      <output data-output-for="backgroundOpacity"></output>
    </label>

    <label>
      Contrast
      <input name="contrast" type="range" min="0.2" max="3" step="0.01" />
      <output data-output-for="contrast"></output>
    </label>

    <label>
      Bias
      <input name="thresholdBias" type="range" min="-0.5" max="0.5" step="0.01" />
      <output data-output-for="thresholdBias"></output>
    </label>

    <label>
      Gamma
      <input name="gamma" type="range" min="0.2" max="3" step="0.01" />
      <output data-output-for="gamma"></output>
    </label>

    <label>
      Noise
      <input name="noiseAmount" type="range" min="0" max="0.6" step="0.01" />
      <output data-output-for="noiseAmount"></output>
    </label>

    <label>
      Ripple scale
      <input name="rippleScale" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleScale"></output>
    </label>

    <label>
      Ripple strength
      <input name="rippleStrength" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleStrength"></output>
    </label>

    <label>
      Ripple viscosity
      <input name="rippleViscosity" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleViscosity"></output>
    </label>

    <label>
      Ripple decay
      <input name="rippleDecay" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleDecay"></output>
    </label>

    <label>
      Chromatic
      <input name="rippleChromatic" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleChromatic"></output>
    </label>

    <label>
      Ripple speed
      <input name="rippleSpeed" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleSpeed"></output>
    </label>

    <label>
      Ripple momentum
      <input name="rippleMomentum" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleMomentum"></output>
    </label>

    <label>
      Ripple trail
      <input name="rippleTrail" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleTrail"></output>
    </label>

    <label>
      Ripple directionality
      <input name="rippleDirectionality" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleDirectionality"></output>
    </label>

    <label>
      Ripple irregularity
      <input name="rippleIrregularity" type="range" min="0" max="100" step="1" />
      <output data-output-for="rippleIrregularity"></output>
    </label>

    <button type="button" data-copy-params>Copy params</button>
    <textarea data-params-output readonly rows="7" spellcheck="false"></textarea>
  </form>
</div>

<script>
  const GLYPH_PRESETS = {
    default: " .:-=+*#%@",
    blocks: " ░▒▓█",
    ascii:
      " `.-':_,^=;><+!rc*/z?sLTv)J7(|Fi{C}fI31tlu[neoZ5Yxjya]2ESwqkP6h9d4VpOGbUAKXHm8RD#$Bg0MNWQ%&@",
    braille:
      " ⠁⠂⠃⠄⠅⠆⠇⠈⠉⠊⠋⠌⠍⠎⠏⠐⠑⠒⠓⠔⠕⠖⠗⠘⠙⠚⠛⠜⠝⠞⠟⠠⠡⠢⠣⠤⠥⠦⠧⠨⠩⠪⠫⠬⠭⠮⠯⠰⠱⠲⠳⠴⠵⠶⠷⠸⠹⠺⠻⠼⠽⠾⠿",
  } as const;

  const DEFAULT_PARAMS = {
    preset: "default",
    cellSize: 5,
    glyphScale: 1.3,
    fontScale: 1.2,
    textColor: "#ffffff",
    backgroundColor: "#000000",
    edgeSoftness: 0.38,
    foregroundBrightness: 1.5,
    midtoneBrightness: 0.53,
    backgroundOpacity: 0,
    contrast: 1.39,
    thresholdBias: -0.03,
    gamma: 1.06,
    noiseAmount: 0,
    rippleScale: 24,
    rippleStrength: 39,
    rippleViscosity: 53,
    rippleDecay: 71,
    rippleChromatic: 100,
    rippleSpeed: 100,
    rippleMomentum: 100,
    rippleTrail: 30,
    rippleDirectionality: 10,
    rippleIrregularity: 30,
  };

  type Params = typeof DEFAULT_PARAMS;

  const MAX_RIPPLES = 16;
  const MIN_DISTANCE_PX = 6;
  const MIN_INTERVAL_MS = 30;

  // ─── GLSL — Dither (INTOCABLE) ────────────────────────────────────────────

  const VERT_SRC = `
    attribute vec2 a_position;
    void main() { gl_Position = vec4(a_position, 0.0, 1.0); }
  `;

  // 4×4 coverage samples unrolled for WebGL 1 compatibility
  const FRAG_SRC = `
    precision highp float;

    uniform sampler2D u_source;
    uniform sampler2D u_atlas;
    uniform vec2 u_resolution;
    uniform float u_cellSize;
    uniform float u_glyphCount;
    uniform vec3 u_textColor;
    uniform vec3 u_bgColor;
    uniform vec3 u_accentColor;
    uniform float u_contrast;
    uniform float u_gamma;
    uniform float u_bias;
    uniform float u_edgeSoftness;
    uniform float u_foreground;
    uniform float u_midtone;
    uniform float u_background;
    uniform float u_noise;

    float smstep(float e0, float e1, float x) {
      float t = clamp((x - e0) / (e1 - e0), 0.0, 1.0);
      return t * t * (3.0 - 2.0 * t);
    }

    float noisehash(float x, float y) {
      return fract(sin(x * 12.9898 + y * 78.233) * 43758.5453);
    }

    void main() {
      vec2 fragPos = gl_FragCoord.xy;
      vec2 cellIdx = floor(fragPos / u_cellSize);
      vec2 withinCell = fract(fragPos / u_cellSize);
      vec2 base = cellIdx * u_cellSize;
      float sOff = u_cellSize / 5.0;

      vec2 cov2 = vec2(0.0);
      cov2 += texture2D(u_source, (base + vec2(1.0,1.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(2.0,1.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(3.0,1.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(4.0,1.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(1.0,2.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(2.0,2.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(3.0,2.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(4.0,2.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(1.0,3.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(2.0,3.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(3.0,3.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(4.0,3.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(1.0,4.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(2.0,4.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(3.0,4.0)*sOff) / u_resolution).rg;
      cov2 += texture2D(u_source, (base + vec2(4.0,4.0)*sOff) / u_resolution).rg;
      cov2 /= 16.0;
      float cov = max(cov2.x, cov2.y);

      if (u_noise > 0.0) {
        cov = clamp(cov + (noisehash(cellIdx.x, cellIdx.y) - 0.5) * u_noise, 0.0, 1.0);
      }

      cov = clamp(cov + u_bias, 0.0, 1.0);
      cov = pow(cov, u_gamma);
      cov = clamp((cov - 0.5) * u_contrast + 0.5, 0.0, 1.0);

      float se = u_edgeSoftness * 0.15;
      float br;
      if (cov < 0.05) {
        br = u_background;
      } else if (cov < 0.25) {
        float t = smstep(0.05 - se, 0.25 + se, cov);
        br = u_background + t * (u_midtone * 0.5 - u_background);
      } else if (cov < 0.5) {
        float t = smstep(0.25 - se, 0.5 + se, cov);
        br = u_midtone * 0.5 + t * (u_midtone * 0.5);
      } else if (cov < 0.75) {
        float t = smstep(0.5 - se, 0.75 + se, cov);
        br = u_midtone + t * (u_foreground * 0.85 - u_midtone);
      } else {
        float t = smstep(0.75 - se, 1.0, cov);
        br = u_foreground * 0.85 + t * (u_foreground * 0.15);
      }

      float gi = clamp(floor(cov * u_glyphCount), 0.0, u_glyphCount - 1.0);
      // clamp withinCell away from edges to prevent glyph bleeding with LINEAR filter
      vec2 sc = clamp(withinCell, 0.5 / u_cellSize, 1.0 - 0.5 / u_cellSize);
      vec2 atlasUV = vec2((gi + sc.x) / u_glyphCount, sc.y);
      float mask = texture2D(u_atlas, atlasUV).r;

      float fringeAmount = clamp((cov2.y - cov2.x) / max(cov, 0.0001), 0.0, 1.0);
      vec3 baseColor = mix(u_textColor, u_accentColor, fringeAmount);
      vec3 colInside = mix(u_bgColor, baseColor, clamp(br, 0.0, 1.0));
      vec3 col = mix(u_bgColor, colInside, mask);
      gl_FragColor = vec4(col, 1.0);
    }
  `;

  // ─── GLSL — Ripple pre-pass ───────────────────────────────────────────────
  // Suma analítica de N pulsos vivos. Sin simulación, sin reflexiones.

  const RIPPLE_LOOP = `
    vec2 disp = vec2(0.0);
    for (int i = 0; i < 16; i++) {
      if (i >= u_rippleCount) break;
      vec4 r = u_ripples[i];
      vec2 vel = u_rippleVel[i];
      vec2 to = uv - r.xy;
      float d = length(to);
      float pulse = exp(-(d * d) / max(u_thickness * u_thickness, 1e-6));
      float lifeT = clamp(r.z / u_lifetime, 0.0, 1.0);
      float decay = lifeT >= 1.0 ? 0.0 : pow(1.0 - lifeT, 2.0);
      // -to/d apunta HACIA el centro → al sumar al uv, muestreamos de un punto
      // más cercano al centro → imagen empujada HACIA AFUERA (lente divergente).
      vec2 dirRadial = d > 0.0001 ? -to / d : vec2(0.0);
      vec2 combined = mix(dirRadial, vel, u_directionality);
      // Lóbulos angulares (rompe simetría esférica). Fase determinista por posición.
      float ang = atan(to.y, to.x);
      float phase = fract(sin(dot(r.xy, vec2(127.1, 311.7))) * 43758.5453) * 6.28318;
      float lobe = cos(ang * 3.0 + phase);
      float irregFactor = 1.0 + u_irregularity * lobe;
      disp += combined * pulse * decay * r.w * u_strength * irregFactor;
    }
  `;

  // PRE_FRAG: fusión displace + chromatic. Cada canal RGB muestrea con offset distinto.
  // En reposo (disp=0) o sin chromatic, R=G=B → dither posterior se comporta como antes.
  const PRE_FRAG = `
    precision highp float;
    uniform sampler2D u_srcRaw;
    uniform vec4 u_ripples[16];
    uniform vec2 u_rippleVel[16];
    uniform int u_rippleCount;
    uniform float u_strength;
    uniform float u_thickness;
    uniform float u_lifetime;
    uniform float u_chromatic;
    uniform float u_directionality;
    uniform float u_irregularity;
    uniform vec2 u_resolution;

    void main() {
      vec2 uv = gl_FragCoord.xy / u_resolution;
      ${RIPPLE_LOOP}
      vec2 maxDispUV = vec2(7.0) / u_resolution;
      disp = clamp(disp, -maxDispUV, maxDispUV);
      // R = main glyph, G = ghost (offset por cromática). B = 0.
      float main = texture2D(u_srcRaw, uv + disp).r;
      float ghost = texture2D(u_srcRaw, uv + disp * (1.0 + u_chromatic)).r;
      gl_FragColor = vec4(main, ghost, 0.0, 1.0);
    }
  `;

  // ─── Helpers ──────────────────────────────────────────────────────────────

  function getThemeColors(): { text: string; bg: string; accent: string } {
    const styles = getComputedStyle(document.documentElement);
    const text = styles.getPropertyValue("--color-text").trim() || "#ffffff";
    const bg = styles.getPropertyValue("--color-bg").trim() || "#000000";
    const accent = styles.getPropertyValue("--color-accent").trim() || "#ffab6c";
    return { text, bg, accent };
  }

  function readMsVar(name: string, fallback: number): number {
    const raw = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    if (raw.endsWith("ms")) return parseFloat(raw);
    if (raw.endsWith("s")) return parseFloat(raw) * 1000;
    return fallback;
  }

  function easeOutCubic(t: number): number {
    const k = 1 - t;
    return 1 - k * k * k;
  }

  function lerp3(
    a: [number, number, number],
    b: [number, number, number],
    t: number,
  ): [number, number, number] {
    return [a[0] + (b[0] - a[0]) * t, a[1] + (b[1] - a[1]) * t, a[2] + (b[2] - a[2]) * t];
  }

  function parseCssColor(value: string): [number, number, number] {
    const v = value.trim();
    const hex = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(v);
    if (hex) {
      return [
        parseInt(hex[1], 16) / 255,
        parseInt(hex[2], 16) / 255,
        parseInt(hex[3], 16) / 255,
      ];
    }
    const rgb = /rgba?\(\s*(\d+(?:\.\d+)?)\s*,\s*(\d+(?:\.\d+)?)\s*,\s*(\d+(?:\.\d+)?)/i.exec(v);
    if (rgb) {
      return [parseFloat(rgb[1]) / 255, parseFloat(rgb[2]) / 255, parseFloat(rgb[3]) / 255];
    }
    return [1, 1, 1];
  }

  function getHeadlineLines(): string[] {
    const el = document.querySelector<HTMLElement>("[data-hero-section] h1");
    if (!el) return [];
    return el.innerText.split("\n").map((l) => l.trim()).filter(Boolean);
  }

  function numberParam(form: HTMLFormElement, name: keyof Params): number {
    const el = form.elements.namedItem(String(name)) as HTMLInputElement | null;
    return el ? parseFloat(el.value) : Number(DEFAULT_PARAMS[name]);
  }

  function getParams(form: HTMLFormElement): Params {
    const preset = (form.elements.namedItem("preset") as HTMLSelectElement | null)?.value;
    const theme = getThemeColors();
    return {
      preset: (
        preset && preset in GLYPH_PRESETS ? preset : DEFAULT_PARAMS.preset
      ) as Params["preset"],
      cellSize: numberParam(form, "cellSize"),
      glyphScale: numberParam(form, "glyphScale"),
      fontScale: numberParam(form, "fontScale"),
      textColor: theme.text,
      backgroundColor: theme.bg,
      edgeSoftness: numberParam(form, "edgeSoftness"),
      foregroundBrightness: numberParam(form, "foregroundBrightness"),
      midtoneBrightness: numberParam(form, "midtoneBrightness"),
      backgroundOpacity: numberParam(form, "backgroundOpacity"),
      contrast: numberParam(form, "contrast"),
      thresholdBias: numberParam(form, "thresholdBias"),
      gamma: numberParam(form, "gamma"),
      noiseAmount: numberParam(form, "noiseAmount"),
      rippleScale: numberParam(form, "rippleScale"),
      rippleStrength: numberParam(form, "rippleStrength"),
      rippleViscosity: numberParam(form, "rippleViscosity"),
      rippleDecay: numberParam(form, "rippleDecay"),
      rippleChromatic: numberParam(form, "rippleChromatic"),
      rippleSpeed: numberParam(form, "rippleSpeed"),
      rippleMomentum: numberParam(form, "rippleMomentum"),
      rippleTrail: numberParam(form, "rippleTrail"),
      rippleDirectionality: numberParam(form, "rippleDirectionality"),
      rippleIrregularity: numberParam(form, "rippleIrregularity"),
    };
  }

  function applyParams(form: HTMLFormElement, params: Params) {
    Object.entries(params).forEach(([name, value]) => {
      const el = form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = String(value);
    });
  }

  function updateOutputs(form: HTMLFormElement) {
    form.querySelectorAll<HTMLOutputElement>("output[data-output-for]").forEach((out) => {
      const input = form.elements.namedItem(out.dataset.outputFor!) as HTMLInputElement | null;
      if (input) out.value = input.value;
    });
  }

  function serializeParams(params: Params): string {
    return JSON.stringify(params, null, 2);
  }

  // ─── WebGL utilities ──────────────────────────────────────────────────────

  function compileShader(gl: WebGLRenderingContext, type: number, src: string): WebGLShader | null {
    const s = gl.createShader(type);
    if (!s) return null;
    gl.shaderSource(s, src);
    gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
      console.error("Shader error:", gl.getShaderInfoLog(s));
      gl.deleteShader(s);
      return null;
    }
    return s;
  }

  function buildProgramFromSrc(
    gl: WebGLRenderingContext,
    vs: string,
    fs: string,
  ): WebGLProgram | null {
    const vert = compileShader(gl, gl.VERTEX_SHADER, vs);
    const frag = compileShader(gl, gl.FRAGMENT_SHADER, fs);
    if (!vert || !frag) return null;
    const prog = gl.createProgram()!;
    gl.attachShader(prog, vert);
    gl.attachShader(prog, frag);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      console.error("Program link error:", gl.getProgramInfoLog(prog));
      return null;
    }
    return prog;
  }

  function makeTexture(gl: WebGLRenderingContext): WebGLTexture | null {
    const tex = gl.createTexture();
    if (!tex) return null;
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    return tex;
  }

  function uploadTexture(
    gl: WebGLRenderingContext,
    tex: WebGLTexture,
    unit: number,
    canvas: HTMLCanvasElement,
  ) {
    gl.activeTexture(gl.TEXTURE0 + unit);
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, 1);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, canvas);
  }

  type FBO = { fbo: WebGLFramebuffer; tex: WebGLTexture; w: number; h: number };

  function makeFBO(gl: WebGLRenderingContext, w: number, h: number): FBO | null {
    const tex = gl.createTexture();
    const fbo = gl.createFramebuffer();
    if (!tex || !fbo) return null;
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, 0);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, w, h, 0, gl.RGBA, gl.UNSIGNED_BYTE, null);
    gl.bindFramebuffer(gl.FRAMEBUFFER, fbo);
    gl.framebufferTexture2D(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.TEXTURE_2D, tex, 0);
    const status = gl.checkFramebufferStatus(gl.FRAMEBUFFER);
    gl.bindFramebuffer(gl.FRAMEBUFFER, null);
    if (status !== gl.FRAMEBUFFER_COMPLETE) {
      gl.deleteTexture(tex);
      gl.deleteFramebuffer(fbo);
      return null;
    }
    return { fbo, tex, w, h };
  }

  function resizeFBO(gl: WebGLRenderingContext, fbo: FBO, w: number, h: number): FBO {
    if (fbo.w === w && fbo.h === h) return fbo;
    gl.bindTexture(gl.TEXTURE_2D, fbo.tex);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, w, h, 0, gl.RGBA, gl.UNSIGNED_BYTE, null);
    fbo.w = w;
    fbo.h = h;
    return fbo;
  }

  // ─── Canvas rendering ─────────────────────────────────────────────────────

  function wrapLine(ctx: CanvasRenderingContext2D, text: string, maxWidth: number): string[] {
    const words = text.split(/\s+/).filter(Boolean);
    if (words.length === 0) return [];
    const out: string[] = [];
    let current = words[0];
    for (let i = 1; i < words.length; i++) {
      const candidate = `${current} ${words[i]}`;
      if (ctx.measureText(candidate).width <= maxWidth) {
        current = candidate;
      } else {
        out.push(current);
        current = words[i];
      }
    }
    out.push(current);
    return out;
  }

  function renderSource(
    canvas: HTMLCanvasElement,
    lines: string[],
    w: number,
    h: number,
    fontFamily: string,
    fontWeight: string,
    computedFontSize: number,
    fontScale: number,
  ) {
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext("2d")!;
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, w, h);
    if (lines.length === 0 || computedFontSize <= 0) return;
    const fontSize = computedFontSize * fontScale;
    const lineHeight = fontSize * 0.92;
    ctx.fillStyle = "#fff";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.font = `${fontWeight} ${fontSize}px ${fontFamily}`;
    const WRAP_INSET = 0.98;
    const wrapped = lines.flatMap((line) => wrapLine(ctx, line, w * WRAP_INSET));
    if (wrapped.length === 0) return;
    const totalH = (wrapped.length - 1) * lineHeight;
    const startY = h * 0.5 - totalH * 0.5;
    wrapped.forEach((line, i) => ctx.fillText(line, w * 0.5, startY + i * lineHeight));
  }

  function buildAtlas(glyphs: string, cellSize: number, glyphScale: number): HTMLCanvasElement {
    const n = glyphs.length;
    const c = document.createElement("canvas");
    c.width = Math.max(1, n * cellSize);
    c.height = Math.max(1, cellSize);
    const ctx = c.getContext("2d")!;
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, c.width, c.height);
    ctx.fillStyle = "#fff";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.font = `${Math.max(1, Math.round(cellSize * glyphScale))}px "Geist Mono","SF Mono",Monaco,monospace`;
    for (let i = 0; i < n; i++) {
      // Clip per-cell para que glyphs > cellSize no se derramen a la celda vecina
      ctx.save();
      ctx.beginPath();
      ctx.rect(i * cellSize, 0, cellSize, cellSize);
      ctx.clip();
      ctx.fillText(glyphs[i], i * cellSize + cellSize * 0.5, cellSize * 0.5);
      ctx.restore();
    }
    return c;
  }

  // ─── Main ─────────────────────────────────────────────────────────────────

  function initGlyphDither() {
    const root = document.querySelector<HTMLElement>("[data-glyph-dither]");
    const glCanvas = root?.querySelector<HTMLCanvasElement>("[data-glyph-output]");
    const form = root?.querySelector<HTMLFormElement>("[data-glyph-controls]");
    const toggle = root?.querySelector<HTMLButtonElement>("[data-glyph-toggle]");
    const copyButton = root?.querySelector<HTMLButtonElement>("[data-copy-params]");
    if (!root || !glCanvas || !form || !toggle || root.dataset.bound === "true") return;

    const gl = glCanvas.getContext("webgl", { premultipliedAlpha: false });
    if (!gl) {
      console.warn("WebGL not supported");
      return;
    }

    // ── Programs ────────────────────────────────────────────────────────────
    const ditherProg = buildProgramFromSrc(gl, VERT_SRC, FRAG_SRC);
    const dispProg = buildProgramFromSrc(gl, VERT_SRC, PRE_FRAG);
    if (!ditherProg || !dispProg) return;

    // Full-screen quad — shared by all programs
    const quadBuf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, quadBuf);
    gl.bufferData(
      gl.ARRAY_BUFFER,
      new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]),
      gl.STATIC_DRAW,
    );

    function bindQuad(prog: WebGLProgram) {
      const loc = gl!.getAttribLocation(prog, "a_position");
      gl!.bindBuffer(gl!.ARRAY_BUFFER, quadBuf);
      gl!.enableVertexAttribArray(loc);
      gl!.vertexAttribPointer(loc, 2, gl!.FLOAT, false, 0, 0);
    }

    // Texture unit assignment:
    //   0 → u_source (dither)   — bound just before dither draw (preDither.tex o srcRaw)
    //   1 → u_atlas (dither)
    //   2 → u_srcRaw (pre-pass)
    const srcRawTex = makeTexture(gl)!;
    const atlasTex = makeTexture(gl)!;

    gl.useProgram(ditherProg);
    bindQuad(ditherProg);
    gl.uniform1i(gl.getUniformLocation(ditherProg, "u_source"), 0);
    gl.uniform1i(gl.getUniformLocation(ditherProg, "u_atlas"), 1);

    const dLoc = {
      res: gl.getUniformLocation(ditherProg, "u_resolution"),
      cell: gl.getUniformLocation(ditherProg, "u_cellSize"),
      glyphs: gl.getUniformLocation(ditherProg, "u_glyphCount"),
      text: gl.getUniformLocation(ditherProg, "u_textColor"),
      bg: gl.getUniformLocation(ditherProg, "u_bgColor"),
      accent: gl.getUniformLocation(ditherProg, "u_accentColor"),
      contrast: gl.getUniformLocation(ditherProg, "u_contrast"),
      gamma: gl.getUniformLocation(ditherProg, "u_gamma"),
      bias: gl.getUniformLocation(ditherProg, "u_bias"),
      edge: gl.getUniformLocation(ditherProg, "u_edgeSoftness"),
      fg: gl.getUniformLocation(ditherProg, "u_foreground"),
      mid: gl.getUniformLocation(ditherProg, "u_midtone"),
      bgOp: gl.getUniformLocation(ditherProg, "u_background"),
      noise: gl.getUniformLocation(ditherProg, "u_noise"),
    };

    const dispLoc = {
      srcRaw: gl.getUniformLocation(dispProg, "u_srcRaw"),
      ripples: gl.getUniformLocation(dispProg, "u_ripples"),
      vel: gl.getUniformLocation(dispProg, "u_rippleVel"),
      count: gl.getUniformLocation(dispProg, "u_rippleCount"),
      strength: gl.getUniformLocation(dispProg, "u_strength"),
      thickness: gl.getUniformLocation(dispProg, "u_thickness"),
      lifetime: gl.getUniformLocation(dispProg, "u_lifetime"),
      chromatic: gl.getUniformLocation(dispProg, "u_chromatic"),
      directionality: gl.getUniformLocation(dispProg, "u_directionality"),
      irregularity: gl.getUniformLocation(dispProg, "u_irregularity"),
      res: gl.getUniformLocation(dispProg, "u_resolution"),
    };
    gl.useProgram(dispProg);
    gl.uniform1i(dispLoc.srcRaw, 2);

    // ── State ───────────────────────────────────────────────────────────────
    const sourceCanvas = document.createElement("canvas");
    let atlasKey = "";
    let lastW = 0;
    let lastH = 0;
    let cachedParams: Params = { ...DEFAULT_PARAMS };
    let raf = 0;
    let pendingKickFrames = 0;
    let displaced: FBO | null = null;

    // Tween de colores del theme (sincronizado con la var --theme-transition-duration).
    const THEME_TWEEN_MS = readMsVar("--theme-transition-duration", 220);
    let currentTextRGB = parseCssColor(getThemeColors().text);
    let currentBgRGB = parseCssColor(getThemeColors().bg);
    let currentAccentRGB = parseCssColor(getThemeColors().accent);
    let prevTextRGB: [number, number, number] = [...currentTextRGB] as [number, number, number];
    let prevBgRGB: [number, number, number] = [...currentBgRGB] as [number, number, number];
    let prevAccentRGB: [number, number, number] = [...currentAccentRGB] as [number, number, number];
    let targetTextRGB: [number, number, number] = [...currentTextRGB] as [number, number, number];
    let targetBgRGB: [number, number, number] = [...currentBgRGB] as [number, number, number];
    let targetAccentRGB: [number, number, number] = [...currentAccentRGB] as [number, number, number];
    let themeTweenStart = -Infinity;
    let rippleAvailable = false;

    // Pulsos
    type Ripple = { x: number; y: number; bornAt: number; amp: number; vx: number; vy: number };
    const ripples: Ripple[] = [];
    const ripplePack = new Float32Array(MAX_RIPPLES * 4);
    const rippleVelPack = new Float32Array(MAX_RIPPLES * 2);
    let lastRippleX = 0;
    let lastRippleY = 0;
    let lastRippleAt = 0;
    let prevMouseX = -1;
    let prevMouseY = -1;

    applyParams(form, DEFAULT_PARAMS);

    function rippleParams() {
      const p = cachedParams;
      const trail = Math.max(0, Math.min(1, p.rippleTrail / 100));
      return {
        strength: (p.rippleStrength / 100) * 0.025,
        thickness: Math.max(0.005, 0.04 - (p.rippleScale / 100) * 0.025),
        lifetime: (0.2 + (p.rippleViscosity / 100) * 0.4) * (1 + trail * 2),
        chromatic: Math.min(1.5, (p.rippleChromatic / 100) * 1.0),
        directionality: Math.max(0, Math.min(1, p.rippleDirectionality / 100)),
        irregularity: Math.max(0, Math.min(1, p.rippleIrregularity / 100)),
        minDistancePx: MIN_DISTANCE_PX * (1 - trail * 0.7),
        minIntervalMs: MIN_INTERVAL_MS * (1 - trail * 0.7),
      };
    }

    function ensureSize(): boolean {
      const rect = root!.getBoundingClientRect();
      const w = Math.floor(rect.width);
      const h = Math.floor(rect.height);
      if (w <= 0 || h <= 0) return false;
      if (glCanvas!.width !== w || glCanvas!.height !== h) {
        glCanvas!.width = w;
        glCanvas!.height = h;
      }
      lastW = w;
      lastH = h;

      if (!displaced) {
        displaced = makeFBO(gl!, w, h);
        rippleAvailable = !!displaced;
      } else {
        displaced = resizeFBO(gl!, displaced, w, h);
      }
      return true;
    }

    function uploadSource() {
      const lines = getHeadlineLines();
      const headline = document.querySelector<HTMLElement>("[data-hero-section] h1");
      const hs = headline ? getComputedStyle(headline) : null;
      const fontFamily = hs?.fontFamily || `"Geist Variable", system-ui, sans-serif`;
      const fontWeight = hs?.fontWeight || "400";
      const computedFontSize = hs ? parseFloat(hs.fontSize) : 64;
      renderSource(
        sourceCanvas,
        lines,
        lastW,
        lastH,
        fontFamily,
        fontWeight,
        computedFontSize,
        cachedParams.fontScale,
      );
      uploadTexture(gl!, srcRawTex, 2, sourceCanvas);
      return computedFontSize;
    }

    function ensureAtlas(effectiveCellSize: number) {
      const glyphs = GLYPH_PRESETS[cachedParams.preset] || GLYPH_PRESETS.default;
      const newAtlasKey = `${cachedParams.preset}:${effectiveCellSize}:${cachedParams.glyphScale}`;
      if (newAtlasKey !== atlasKey) {
        const atlas = buildAtlas(glyphs, effectiveCellSize, cachedParams.glyphScale);
        uploadTexture(gl!, atlasTex, 1, atlas);
        atlasKey = newAtlasKey;
      }
      return glyphs;
    }

    function packRipples(now: number) {
      // Filter dead in-place
      const lifetime = rippleParams().lifetime;
      let w = 0;
      for (let i = 0; i < ripples.length; i++) {
        const age = (now - ripples[i].bornAt) / 1000;
        if (age < lifetime) {
          if (w !== i) ripples[w] = ripples[i];
          w++;
        }
      }
      ripples.length = w;
      // Pack
      ripplePack.fill(0);
      rippleVelPack.fill(0);
      for (let i = 0; i < ripples.length && i < MAX_RIPPLES; i++) {
        const r = ripples[i];
        const age = (now - r.bornAt) / 1000;
        ripplePack[i * 4 + 0] = r.x;
        ripplePack[i * 4 + 1] = r.y;
        ripplePack[i * 4 + 2] = age;
        ripplePack[i * 4 + 3] = r.amp;
        rippleVelPack[i * 2 + 0] = r.vx;
        rippleVelPack[i * 2 + 1] = r.vy;
      }
    }

    function setRippleUniforms() {
      const rp = rippleParams();
      gl!.uniform4fv(dispLoc.ripples, ripplePack);
      gl!.uniform2fv(dispLoc.vel, rippleVelPack);
      gl!.uniform1i(dispLoc.count, ripples.length);
      gl!.uniform1f(dispLoc.strength, rp.strength);
      gl!.uniform1f(dispLoc.thickness, rp.thickness);
      gl!.uniform1f(dispLoc.lifetime, rp.lifetime);
      gl!.uniform1f(dispLoc.chromatic, rp.chromatic);
      gl!.uniform1f(dispLoc.directionality, rp.directionality);
      gl!.uniform1f(dispLoc.irregularity, rp.irregularity);
    }

    function runPrePass() {
      if (!displaced) return;
      gl!.useProgram(dispProg!);
      bindQuad(dispProg!);
      gl!.bindFramebuffer(gl!.FRAMEBUFFER, displaced.fbo);
      gl!.viewport(0, 0, lastW, lastH);
      gl!.activeTexture(gl!.TEXTURE2);
      gl!.bindTexture(gl!.TEXTURE_2D, srcRawTex);
      gl!.uniform2f(dispLoc.res, lastW, lastH);
      setRippleUniforms();
      gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
    }

    function runDither(sourceTex: WebGLTexture) {
      const params = cachedParams;
      const headline = document.querySelector<HTMLElement>("[data-hero-section] h1");
      const computedFontSize = headline ? parseFloat(getComputedStyle(headline).fontSize) : 64;
      const REFERENCE_FONT_SIZE = 100;
      const effectiveCellSize = Math.max(
        2,
        Math.round(params.cellSize * (computedFontSize * params.fontScale) / REFERENCE_FONT_SIZE),
      );
      const glyphs = ensureAtlas(effectiveCellSize);

      gl!.useProgram(ditherProg!);
      bindQuad(ditherProg!);
      gl!.bindFramebuffer(gl!.FRAMEBUFFER, null);
      gl!.viewport(0, 0, lastW, lastH);

      gl!.activeTexture(gl!.TEXTURE0);
      gl!.bindTexture(gl!.TEXTURE_2D, sourceTex);
      gl!.activeTexture(gl!.TEXTURE1);
      gl!.bindTexture(gl!.TEXTURE_2D, atlasTex);

      gl!.uniform2f(dLoc.res, lastW, lastH);
      gl!.uniform1f(dLoc.cell, effectiveCellSize);
      gl!.uniform1f(dLoc.glyphs, glyphs.length);
      gl!.uniform3f(dLoc.text, currentTextRGB[0], currentTextRGB[1], currentTextRGB[2]);
      gl!.uniform3f(dLoc.bg, currentBgRGB[0], currentBgRGB[1], currentBgRGB[2]);
      gl!.uniform3f(dLoc.accent, currentAccentRGB[0], currentAccentRGB[1], currentAccentRGB[2]);
      gl!.uniform1f(dLoc.contrast, params.contrast);
      gl!.uniform1f(dLoc.gamma, params.gamma);
      gl!.uniform1f(dLoc.bias, params.thresholdBias);
      gl!.uniform1f(dLoc.edge, params.edgeSoftness);
      gl!.uniform1f(dLoc.fg, params.foregroundBrightness);
      gl!.uniform1f(dLoc.mid, params.midtoneBrightness);
      gl!.uniform1f(dLoc.bgOp, params.backgroundOpacity);
      gl!.uniform1f(dLoc.noise, params.noiseAmount);
      gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
    }

    function frame() {
      cachedParams = getParams(form!);
      if (!ensureSize()) {
        raf = 0;
        return;
      }
      uploadSource();

      const now = performance.now();
      packRipples(now);

      // Avanzar tween de tema.
      const tweenT = themeTweenStart === -Infinity
        ? 1
        : Math.max(0, Math.min(1, (now - themeTweenStart) / THEME_TWEEN_MS));
      const themeEased = easeOutCubic(tweenT);
      currentTextRGB = lerp3(prevTextRGB, targetTextRGB, themeEased);
      currentBgRGB = lerp3(prevBgRGB, targetBgRGB, themeEased);
      currentAccentRGB = lerp3(prevAccentRGB, targetAccentRGB, themeEased);

      if (rippleAvailable) {
        runPrePass();
        runDither(displaced!.tex);
      } else {
        runDither(srcRawTex);
      }

      root!.style.backgroundColor = cachedParams.backgroundColor;
      const paramsOut = root!.querySelector<HTMLTextAreaElement>("[data-params-output]");
      if (paramsOut) paramsOut.value = serializeParams(cachedParams);
      updateOutputs(form!);

      if (pendingKickFrames > 0) pendingKickFrames--;
      const themeAnimating = tweenT < 1;
      if (ripples.length > 0 || pendingKickFrames > 0 || themeAnimating) {
        raf = requestAnimationFrame(frame);
      } else {
        raf = 0;
      }
    }

    function kick(frames: number = 2) {
      if (frames > pendingKickFrames) pendingKickFrames = frames;
      if (!raf) raf = requestAnimationFrame(frame);
    }

    // ── Mouse → ripple injection ────────────────────────────────────────────
    function onMouseMove(e: MouseEvent) {
      if (!rippleAvailable) return;
      const rect = root!.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const now = performance.now();

      let dx = 0;
      let dy = 0;
      let mag = 0;
      if (prevMouseX >= 0) {
        dx = x - prevMouseX;
        dy = y - prevMouseY;
        mag = Math.hypot(dx, dy);
      }
      prevMouseX = x;
      prevMouseY = y;

      if (mag < 0.5) return;

      const rp = rippleParams();
      const distFromLast =
        lastRippleAt === 0 ? Infinity : Math.hypot(x - lastRippleX, y - lastRippleY);
      const dtFromLast = now - lastRippleAt;
      const shouldEmit =
        lastRippleAt === 0 ||
        distFromLast >= rp.minDistancePx ||
        dtFromLast >= rp.minIntervalMs;
      if (!shouldEmit) return;

      const momentumFactor = (cachedParams.rippleMomentum / 100) * 3.0;
      const amp = Math.max(0.05, Math.min(1, mag * momentumFactor * 0.01));
      const u = Math.max(0, Math.min(1, x / Math.max(1, rect.width)));
      // gl_FragCoord Y origin is bottom-left; CSS y grows downward → flip
      const v = Math.max(0, Math.min(1, 1 - y / Math.max(1, rect.height)));
      // Velocidad unitaria del ratón. CSS y crece hacia abajo, GLSL hacia arriba → invertir vy.
      const invMag = mag > 0 ? 1 / mag : 0;
      const vx = dx * invMag;
      const vy = -dy * invMag;

      if (ripples.length >= MAX_RIPPLES) ripples.shift();
      ripples.push({ x: u, y: v, bornAt: now, amp, vx, vy });
      lastRippleX = x;
      lastRippleY = y;
      lastRippleAt = now;

      if (!raf) raf = requestAnimationFrame(frame);
    }

    function onMouseLeave() {
      prevMouseX = -1;
      prevMouseY = -1;
    }

    root.addEventListener("mousemove", onMouseMove);
    root.addEventListener("mouseleave", onMouseLeave);

    const themeObserver = new MutationObserver(() => {
      const theme = getThemeColors();
      const newText = parseCssColor(theme.text);
      const newBg = parseCssColor(theme.bg);
      const newAccent = parseCssColor(theme.accent);
      if (
        newText[0] === targetTextRGB[0] &&
        newText[1] === targetTextRGB[1] &&
        newText[2] === targetTextRGB[2] &&
        newBg[0] === targetBgRGB[0] &&
        newBg[1] === targetBgRGB[1] &&
        newBg[2] === targetBgRGB[2] &&
        newAccent[0] === targetAccentRGB[0] &&
        newAccent[1] === targetAccentRGB[1] &&
        newAccent[2] === targetAccentRGB[2]
      ) return;
      prevTextRGB = [...currentTextRGB] as [number, number, number];
      prevBgRGB = [...currentBgRGB] as [number, number, number];
      prevAccentRGB = [...currentAccentRGB] as [number, number, number];
      targetTextRGB = newText;
      targetBgRGB = newBg;
      targetAccentRGB = newAccent;
      themeTweenStart = performance.now();
      if (!raf) raf = requestAnimationFrame(frame);
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme", "data-theme-mode"],
    });

    // ── Knob interactions ───────────────────────────────────────────────────
    let deferredTimer = 0;
    const scheduleKick = () => kick();
    const scheduleDeferred = () => {
      window.clearTimeout(deferredTimer);
      deferredTimer = window.setTimeout(scheduleKick, 80);
      updateOutputs(form!);
    };

    toggle.addEventListener("click", () => {
      const hidden = form!.hidden;
      form!.hidden = !hidden;
      toggle.setAttribute("aria-expanded", String(hidden));
    });

    form.addEventListener("input", scheduleDeferred);
    form.addEventListener("change", scheduleKick);

    copyButton?.addEventListener("click", async () => {
      const value = serializeParams(getParams(form!));
      const out = root!.querySelector<HTMLTextAreaElement>("[data-params-output]");
      if (out) {
        out.value = value;
        out.select();
      }
      try {
        await navigator.clipboard.writeText(value);
      } catch {}
    });

    const onResize = () => kick();
    window.addEventListener("resize", onResize);
    document.fonts.ready.then(scheduleKick);

    // Initial paint
    kick();

    // ── Cleanup ─────────────────────────────────────────────────────────────
    const cleanup = () => {
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
      window.clearTimeout(deferredTimer);
      window.removeEventListener("resize", onResize);
      root!.removeEventListener("mousemove", onMouseMove);
      root!.removeEventListener("mouseleave", onMouseLeave);
      themeObserver.disconnect();
      gl!.deleteTexture(srcRawTex);
      gl!.deleteTexture(atlasTex);
      gl!.deleteProgram(ditherProg);
      gl!.deleteProgram(dispProg);
      gl!.deleteBuffer(quadBuf);
      if (displaced) {
        gl!.deleteTexture(displaced.tex);
        gl!.deleteFramebuffer(displaced.fbo);
      }
      ripples.length = 0;
      root!.dataset.bound = "";
      document.removeEventListener("astro:before-swap", cleanup);
    };
    document.addEventListener("astro:before-swap", cleanup);

    root.dataset.bound = "true";
  }

  document.addEventListener("astro:page-load", initGlyphDither);
  if (document.readyState !== "loading") {
    initGlyphDither();
  } else {
    document.addEventListener("DOMContentLoaded", initGlyphDither, { once: true });
  }
</script>
