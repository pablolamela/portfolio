---
import styles from "./HeroGlyphDither.module.scss";
---

<div class={styles.root} data-glyph-dither>
  <canvas class={styles.source} data-glyph-source aria-hidden="true"></canvas>
  <div class={styles.grid} data-glyph-grid aria-hidden="true"></div>

  <button class={styles.toggle} type="button" data-glyph-toggle aria-expanded="false">
    Glyph knobs
  </button>

  <form class={styles.controls} data-glyph-controls hidden>
    <label>
      Preset
      <select name="preset">
        <option value="ascii">ASCII</option>
        <option value="default">Default</option>
        <option value="blocks">Blocks</option>
        <option value="braille">Braille</option>
      </select>
    </label>

    <label>
      Cell
      <input name="cellSize" type="range" min="4" max="16" step="1" />
      <output data-output-for="cellSize"></output>
    </label>

    <label>
      Font
      <input name="fontScale" type="range" min="0.45" max="1.2" step="0.01" />
      <output data-output-for="fontScale"></output>
    </label>

    <label>
      Edge
      <input name="edgeSoftness" type="range" min="0" max="1" step="0.01" />
      <output data-output-for="edgeSoftness"></output>
    </label>

    <label>
      Foreground
      <input name="foregroundBrightness" type="range" min="0" max="1.5" step="0.01" />
      <output data-output-for="foregroundBrightness"></output>
    </label>

    <label>
      Midtone
      <input name="midtoneBrightness" type="range" min="0" max="1.2" step="0.01" />
      <output data-output-for="midtoneBrightness"></output>
    </label>

    <label>
      Background
      <input name="backgroundOpacity" type="range" min="0" max="0.12" step="0.005" />
      <output data-output-for="backgroundOpacity"></output>
    </label>

    <label>
      Contrast
      <input name="contrast" type="range" min="0.2" max="3" step="0.01" />
      <output data-output-for="contrast"></output>
    </label>

    <label>
      Bias
      <input name="thresholdBias" type="range" min="-0.5" max="0.5" step="0.01" />
      <output data-output-for="thresholdBias"></output>
    </label>

    <label>
      Gamma
      <input name="gamma" type="range" min="0.2" max="3" step="0.01" />
      <output data-output-for="gamma"></output>
    </label>

    <label>
      Noise
      <input name="noiseAmount" type="range" min="0" max="0.6" step="0.01" />
      <output data-output-for="noiseAmount"></output>
    </label>

    <label>
      Color
      <input name="textColor" type="color" />
    </label>

    <label>
      Background
      <input name="backgroundColor" type="color" />
    </label>

    <button type="button" data-copy-params>Copy params</button>
    <textarea data-params-output readonly rows="7" spellcheck="false"></textarea>
  </form>
</div>

<script>
  const GLYPH_PRESETS = {
    default: " .:-=+*#%@",
    blocks: " ░▒▓█",
    ascii:
      " `.-':_,^=;><+!rc*/z?sLTv)J7(|Fi{C}fI31tlu[neoZ5Yxjya]2ESwqkP6h9d4VpOGbUAKXHm8RD#$Bg0MNWQ%&@",
    braille:
      " ⠁⠂⠃⠄⠅⠆⠇⠈⠉⠊⠋⠌⠍⠎⠏⠐⠑⠒⠓⠔⠕⠖⠗⠘⠙⠚⠛⠜⠝⠞⠟⠠⠡⠢⠣⠤⠥⠦⠧⠨⠩⠪⠫⠬⠭⠮⠯⠰⠱⠲⠳⠴⠵⠶⠷⠸⠹⠺⠻⠼⠽⠾⠿",
  } as const;

  const DEFAULT_PARAMS = {
    preset: "default",
    cellSize: 8,
    fontScale: 1,
    textColor: "#ffffff",
    backgroundColor: "#000000",
    edgeSoftness: 0.36,
    foregroundBrightness: 1,
    midtoneBrightness: 0.62,
    backgroundOpacity: 0,
    contrast: 1.7,
    thresholdBias: -0.02,
    gamma: 0.82,
    noiseAmount: 0,
  };

  type Params = typeof DEFAULT_PARAMS;

  function smoothstep(edge0: number, edge1: number, x: number): number {
    const t = Math.max(0, Math.min(1, (x - edge0) / (edge1 - edge0)));
    return t * t * (3 - 2 * t);
  }

  function hash(x: number, y: number): number {
    const n = Math.sin(x * 12.9898 + y * 78.233) * 43758.5453;
    return n - Math.floor(n);
  }

  function parseHex(hex: string) {
    const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return result
      ? {
          r: parseInt(result[1], 16),
          g: parseInt(result[2], 16),
          b: parseInt(result[3], 16),
        }
      : { r: 255, g: 255, b: 255 };
  }

  function escapeGlyph(glyph: string): string {
    if (glyph === " ") return "&nbsp;";
    return glyph
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function getHeadlineLines(): string[] {
    const headline = document.querySelector<HTMLElement>("[data-hero-section] h1");
    if (!headline) return [];
    return headline.innerText
      .split("\n")
      .map((line) => line.trim())
      .filter(Boolean);
  }

  function numberParam(form: HTMLFormElement, name: keyof Params): number {
    const el = form.elements.namedItem(String(name)) as HTMLInputElement | null;
    return el ? parseFloat(el.value) : Number(DEFAULT_PARAMS[name]);
  }

  function getParams(form: HTMLFormElement): Params {
    const preset = (form.elements.namedItem("preset") as HTMLSelectElement | null)?.value;
    const textColor = (form.elements.namedItem("textColor") as HTMLInputElement | null)?.value;
    const backgroundColor = (form.elements.namedItem("backgroundColor") as HTMLInputElement | null)?.value;

    return {
      preset: (preset && preset in GLYPH_PRESETS ? preset : DEFAULT_PARAMS.preset) as Params["preset"],
      cellSize: numberParam(form, "cellSize"),
      fontScale: numberParam(form, "fontScale"),
      textColor: textColor || DEFAULT_PARAMS.textColor,
      backgroundColor: backgroundColor || DEFAULT_PARAMS.backgroundColor,
      edgeSoftness: numberParam(form, "edgeSoftness"),
      foregroundBrightness: numberParam(form, "foregroundBrightness"),
      midtoneBrightness: numberParam(form, "midtoneBrightness"),
      backgroundOpacity: numberParam(form, "backgroundOpacity"),
      contrast: numberParam(form, "contrast"),
      thresholdBias: numberParam(form, "thresholdBias"),
      gamma: numberParam(form, "gamma"),
      noiseAmount: numberParam(form, "noiseAmount"),
    };
  }

  function applyParams(form: HTMLFormElement, params: Params) {
    Object.entries(params).forEach(([name, value]) => {
      const el = form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = String(value);
    });
  }

  function updateOutputs(form: HTMLFormElement) {
    form.querySelectorAll<HTMLOutputElement>("output[data-output-for]").forEach((output) => {
      const name = output.dataset.outputFor;
      const input = name ? (form.elements.namedItem(name) as HTMLInputElement | null) : null;
      if (input) output.value = input.value;
    });
  }

  function serializeParams(params: Params): string {
    return JSON.stringify(params, null, 2);
  }

  function renderGlyphs(root: HTMLElement, canvas: HTMLCanvasElement, grid: HTMLElement, form: HTMLFormElement) {
    const params = getParams(form);
    const lines = getHeadlineLines();
    const rect = root.getBoundingClientRect();
    const width = Math.floor(rect.width);
    const height = Math.floor(rect.height);
    if (width <= 0 || height <= 0 || lines.length === 0) return;

    const scale = 2;
    canvas.width = width * scale;
    canvas.height = height * scale;

    const ctx = canvas.getContext("2d", { willReadFrequently: true });
    if (!ctx) return;

    const headline = document.querySelector<HTMLElement>("[data-hero-section] h1");
    const headlineStyles = headline ? getComputedStyle(headline) : null;
    const fontFamily = headlineStyles?.fontFamily || `"Geist Variable", system-ui, sans-serif`;
    const fontWeight = headlineStyles?.fontWeight || "400";

    ctx.fillStyle = "#000000";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = "high";
    ctx.fillStyle = "#ffffff";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";

    ctx.font = `${fontWeight} ${100 * scale}px ${fontFamily}`;
    const widest = Math.max(...lines.map((line) => ctx.measureText(line).width));
    const fitFont = widest > 0 ? (width * 0.96 * 100 * scale) / widest : 128 * scale;
    const fontSize = Math.min(fitFont, height * 0.26 * scale) * params.fontScale;
    const lineHeight = fontSize * 1.12;
    const totalHeight = (lines.length - 1) * lineHeight;
    const startY = canvas.height * 0.5 - totalHeight * 0.5;

    ctx.font = `${fontWeight} ${fontSize}px ${fontFamily}`;
    lines.forEach((line, index) => {
      ctx.fillText(line, canvas.width * 0.5, startY + index * lineHeight);
    });

    const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    const pixels = imageData.data;
    const cols = Math.floor(width / params.cellSize);
    const rows = Math.floor(height / params.cellSize);
    const glyphs = GLYPH_PRESETS[params.preset] || GLYPH_PRESETS.default;
    const baseColor = parseHex(params.textColor);
    const nodes: string[] = [];
    const samples = 4;
    const sampleOffset = (params.cellSize * scale) / (samples + 1);

    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        let totalCoverage = 0;

        for (let sy = 1; sy <= samples; sy++) {
          for (let sx = 1; sx <= samples; sx++) {
            const px = Math.floor(col * params.cellSize * scale + sx * sampleOffset);
            const py = Math.floor(row * params.cellSize * scale + sy * sampleOffset);
            const idx = (py * canvas.width + px) * 4;
            totalCoverage += pixels[idx] / 255;
          }
        }

        let coverage = totalCoverage / (samples * samples);

        if (params.noiseAmount > 0) {
          coverage = Math.max(0, Math.min(1, coverage + (hash(col, row) - 0.5) * params.noiseAmount));
        }

        coverage = Math.max(0, Math.min(1, coverage + params.thresholdBias));
        coverage = Math.pow(coverage, params.gamma);
        coverage = Math.max(0, Math.min(1, (coverage - 0.5) * params.contrast + 0.5));

        const softEdge = params.edgeSoftness * 0.15;
        let brightness: number;

        if (coverage < 0.05) {
          brightness = params.backgroundOpacity;
        } else if (coverage < 0.25) {
          const t = smoothstep(0.05 - softEdge, 0.25 + softEdge, coverage);
          brightness = params.backgroundOpacity + t * (params.midtoneBrightness * 0.5 - params.backgroundOpacity);
        } else if (coverage < 0.5) {
          const t = smoothstep(0.25 - softEdge, 0.5 + softEdge, coverage);
          brightness = params.midtoneBrightness * 0.5 + t * (params.midtoneBrightness - params.midtoneBrightness * 0.5);
        } else if (coverage < 0.75) {
          const t = smoothstep(0.5 - softEdge, 0.75 + softEdge, coverage);
          brightness = params.midtoneBrightness + t * (params.foregroundBrightness * 0.85 - params.midtoneBrightness);
        } else {
          const t = smoothstep(0.75 - softEdge, 1, coverage);
          brightness = params.foregroundBrightness * 0.85 + t * (params.foregroundBrightness - params.foregroundBrightness * 0.85);
        }

        if (coverage < 0.015 && params.backgroundOpacity <= 0.001) continue;
        if (brightness <= 0.002) continue;

        const glyphIndex = Math.min(glyphs.length - 1, Math.floor(coverage * glyphs.length));
        const glyph = escapeGlyph(glyphs[glyphIndex]);
        const r = Math.round(baseColor.r * brightness);
        const g = Math.round(baseColor.g * brightness);
        const b = Math.round(baseColor.b * brightness);

        nodes.push(
          `<span style="left:${col * params.cellSize}px;top:${row * params.cellSize}px;width:${params.cellSize}px;height:${params.cellSize}px;color:rgb(${r},${g},${b});">${glyph}</span>`,
        );
      }
    }

    root.style.backgroundColor = params.backgroundColor;
    grid.style.fontSize = `${params.cellSize}px`;
    grid.style.lineHeight = `${params.cellSize}px`;
    grid.innerHTML = nodes.join("");

    const output = root.querySelector<HTMLTextAreaElement>("[data-params-output]");
    if (output) output.value = serializeParams(params);
    updateOutputs(form);
  }

  function initGlyphDither() {
    const root = document.querySelector<HTMLElement>("[data-glyph-dither]");
    const canvas = root?.querySelector<HTMLCanvasElement>("[data-glyph-source]");
    const grid = root?.querySelector<HTMLElement>("[data-glyph-grid]");
    const form = root?.querySelector<HTMLFormElement>("[data-glyph-controls]");
    const toggle = root?.querySelector<HTMLButtonElement>("[data-glyph-toggle]");
    const copyButton = root?.querySelector<HTMLButtonElement>("[data-copy-params]");
    if (!root || !canvas || !grid || !form || !toggle || root.dataset.bound === "true") return;

    applyParams(form, DEFAULT_PARAMS);

    let frame = 0;
    let timer = 0;
    const scheduleRender = () => {
      if (frame) cancelAnimationFrame(frame);
      frame = requestAnimationFrame(() => renderGlyphs(root, canvas, grid, form));
    };
    const scheduleRenderDeferred = () => {
      window.clearTimeout(timer);
      timer = window.setTimeout(scheduleRender, 80);
      updateOutputs(form);
    };

    toggle.addEventListener("click", () => {
      const isHidden = form.hidden;
      form.hidden = !isHidden;
      toggle.setAttribute("aria-expanded", String(isHidden));
    });

    form.addEventListener("input", scheduleRenderDeferred);
    form.addEventListener("change", scheduleRender);
    copyButton?.addEventListener("click", async () => {
      const value = serializeParams(getParams(form));
      const output = root.querySelector<HTMLTextAreaElement>("[data-params-output]");
      if (output) {
        output.value = value;
        output.select();
      }
      try {
        await navigator.clipboard.writeText(value);
      } catch {}
    });

    root.dataset.bound = "true";
    window.addEventListener("resize", scheduleRender);
    scheduleRender();
  }

  document.addEventListener("astro:page-load", initGlyphDither);
  if (document.readyState !== "loading") {
    initGlyphDither();
  } else {
    document.addEventListener("DOMContentLoaded", initGlyphDither, { once: true });
  }
</script>
