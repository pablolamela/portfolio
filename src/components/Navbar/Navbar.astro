---
import Button from "@/components/Button";
import style from "./navbar.module.scss";
import { links } from "@/config/site";

export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const isHome = currentPath === "/";

const contactLabel = isHome ? "Contact" : "Close";
const contactHref = isHome ? links.mailto : "/";
---

<nav class={style.Navbar} aria-label="Primary">
  <div class={style.Navbar_inner}>
    <div class={style.Navbar_left}>
      <Button href="/" label="Pablo Lamela" class={style.Navbar_brand} />
    </div>

    <div class={style.Navbar_center}>
      <Button href="/info" label="Info" />
    </div>

    <div class={style.Navbar_right}>
      <Button href={contactHref} label={contactLabel} />
    </div>
  </div>
</nav>
