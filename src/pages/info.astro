---
import Base from "../layouts/Base.astro";
import Button from "@/components/Button";
import s from "../styles/info.module.scss";
import { Image } from "astro:assets";
import portrait from "../images/portrait.webp";
---

<Base title="Info">
  <main class={s.main}>
    <div class={s.name}>
      <h1 class="label">I am Pablo Lamela,</h1>
      <h2 class="muted label">Product Designer</h2>
    </div>
    <section class={s.grid}>
      <div class={s.intro}>
        <p>
          Focused on turning complex systems into clear, scalable experiences. I work on B2B products, data platforms, and AI-driven tools, designing structured user flows, interfaces, and design systems for complex environments.
        </p>
        <p>
          I collaborate closely with developers throughout the product lifecycle and often work directly in code to build and validate solutions. I also integrate AI into my workflow to accelerate exploration, prototype ideas, and reduce friction between design and implementation.
        </p>
      </div>
      <div class={s.portrait}>
        <Image src={portrait} alt="Portrait of Pablo Lamela" loading="eager" />
      </div>
      <div class={s.links}>
        <Button href="mailto:pablo.lamela50@gmail.com" label="Email" />
        <Button href="https://www.linkedin.com/in/pablo-lamela/" label="Linkedin" external={true} />
        <Button href="/EN-pablo-lamela-cv.pdf" label="Download CV" external={true} />
      </div>

      <div class={s.experience}>
        <h3 class="muted label">Experience</h3>
        <p class="body">
          Diverger <span class="muted">Product Designer</span><br />
          Trileuco Solutions <span class="muted">Product Designer</span><br />
          Visual Publinet <span class="muted">Web Designer</span><br />
          Grupo Inverdama <span class="muted">Graphic Designer</span><br />
          Sanzza <span class="muted">Graphic Designer Intern</span>
        </p>
      </div>
      <div class={s.projects} data-nosnippet>
        <h3 class="muted label">Projects</h3>
        <p class="body" data-nosnippet>
          Diverger Website<br />
          iMBranded<br />
          YepCode<br />
          Delta <span class="muted">Leading textile company</span><br />
          Denodo<br />
          Political Intelligence
        </p>
      </div>
      <div class={s.industries}>
        <h3 class="muted label">Industries</h3>
        <p class="body">
          B2B & SaaS<br />
          AI & Automation<br />
          Data Platforms<br />
          DevOps<br />
          Retail<br />
          Augmented Reality
        </p>
      </div>
      <div class={s.tools}>
        <h3 class="muted label">Tools</h3>
        <p class="body">
          Figma<br />
          HTML/CSS<br />
          Webflow<br />
          Rive<br />
          Spline<br />
          Jira
        </p>
      </div>
      <div class={s.capabilities}>
        <h3 class="muted label">Capabilities</h3>
        <p class="body">
          Product Design<br />
          UX/UI for complex systems<br />
          User Flows & Information Architecture<br />
          Design Systems<br />
          Interaction Design<br />
          Component-based Design<br />
          Design to Code
        </p>
      </div>
      <div class={s.workflow}>
        <h3 class="muted label">Workflow</h3>
        <p class="body">
          AI-assisted workflows<br />
          Design to Code<br />
          Component-driven Design <br />
          Design systems in code<br />
          Close collaboration with engineering
        </p>
      </div>
    </section>
  </main>
</Base>
