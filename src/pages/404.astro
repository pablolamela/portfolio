---
import "../styles/globals.scss";
import s from "../styles/notfound.module.scss";
import GlyphDither from "@/components/fx/GlyphDither";
import Button from "@/components/ui/Button";
const pageTitle = "404 — Página no encontrada";
---

<!doctype html>
<html lang="es" class={s.Html}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex" />
    <!-- Fonts (standalone page — does not inherit the Base layout head) -->
    <link rel="preconnect" href="https://rsms.me" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <!-- Geist Mono drives the dithered "404" shape -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class={s.Body}>
    <main class={s.Main}>
      <section class={s.fourohfour} aria-label="404 — Página no encontrada">
        <h1 class={s.srOnly}>404 — Página no encontrada</h1>
        <div class={s.viewer} aria-hidden="true">
          <GlyphDither text="404" />
        </div>
      </section>

      <div class={s.message}>
        <p class="label">This is not the page you are looking for</p>
        <Button href="/" label="Go back" />
      </div>
    </main>
  </body>
</html>
